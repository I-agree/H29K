# Hinlink H29K (RK3528) U-Boot defconfig
# OpenWrt 25.12+ Linux6.12

# ===== 架构配置（核心修正：ARM64 依赖 ARM 架构，关闭 ARM 会导致架构回退到默认 SANDBOX） =====
CONFIG_ARM=y
CONFIG_ARM64=y
CONFIG_SKIP_LOWLEVEL_INIT=y
CONFIG_COUNTER_FREQUENCY=24000000

# ===== 平台与板级基础配置 =====
CONFIG_ARCH_ROCKCHIP=y
CONFIG_DEFAULT_DEVICE_TREE="rockchip/rk3528-hinlink-h29k"
CONFIG_ROCKCHIP_RK3528=y
CONFIG_SYS_LOAD_ADDR=0x08080000
CONFIG_TEXT_BASE=0x00040000
CONFIG_DEBUG_UART_BASE=0xFF9F0000
CONFIG_DEBUG_UART_CLOCK=24000000
CONFIG_DEBUG_UART=y
CONFIG_DEFAULT_FDT_FILE="rockchip/rk3528-hinlink-h29k.dtb"
# CONFIG_DISPLAY_CPUINFO is not set

# ===== 关闭依赖专属板级代码的功能（无H29K专属板级C代码，开启会链接失败） =====
# CONFIG_BOARD_RNG_SEED is not set

# ===== SPL 启动基础配置 =====
CONFIG_SPL=y
CONFIG_SPL_MAX_SIZE=0x40000
# CONFIG_SPL_RAW_IMAGE_SUPPORT is not set
CONFIG_SPL_DM=y
CONFIG_SPL_OF_CONTROL=y
CONFIG_SPL_OF_LIBFDT=y
CONFIG_OF_SPL_REMOVE_PROPS="clock-names interrupt-parent assigned-clocks assigned-clock-rates assigned-clock-parents"

# ===== 命令行功能 =====
CONFIG_CMD_MEMINFO=y
CONFIG_CMD_MEMINFO_MAP=y
CONFIG_CMD_ADC=y
CONFIG_CMD_GPIO=y
CONFIG_CMD_GPT=y
CONFIG_CMD_MISC=y
CONFIG_CMD_MMC=y
CONFIG_CMD_USB=y
CONFIG_CMD_ROCKUSB=y
CONFIG_CMD_USB_MASS_STORAGE=y
# CONFIG_CMD_SETEXPR is not set
CONFIG_CMD_RNG=y
CONFIG_CMD_REGULATOR=y
# CONFIG_SPL_DOS_PARTITION is not set

# ===== 外设驱动 =====
CONFIG_BUTTON=y
CONFIG_BUTTON_ADC=y
# CONFIG_USB_FUNCTION_FASTBOOT is not set
CONFIG_ROCKCHIP_GPIO=y
CONFIG_LED=y
CONFIG_LED_GPIO=y
CONFIG_SUPPORT_EMMC_RPMB=y

# ===== 存储驱动 =====
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_SDMA=y
CONFIG_MMC_SDHCI_ROCKCHIP=y

# ===== 网络驱动 =====
CONFIG_PHY_REALTEK=y
CONFIG_DM_MDIO=y
CONFIG_DWC_ETH_QOS=y
CONFIG_DWC_ETH_QOS_ROCKCHIP=y

# ===== PHY 驱动 =====
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PHY_ROCKCHIP_NANENG_COMBOPHY=y

# ===== 电源与时钟 =====
CONFIG_REGULATOR_PWM=y
CONFIG_DM_REGULATOR_GPIO=y
CONFIG_PWM_ROCKCHIP=y

# ===== 串口配置 =====
CONFIG_BAUDRATE=1500000
CONFIG_DEBUG_UART_SHIFT=2
CONFIG_SYS_NS16550_MEM32=y

# ===== USB 驱动 =====
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_GENERIC=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GENERIC=y
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_DOWNLOAD=y
CONFIG_USB_FUNCTION_ROCKUSB=y

CONFIG_ERRNO_STR=y

# ===== 核心基础依赖（必选，缺失会导致全量符号未定义） =====
CONFIG_DM=y
CONFIG_OF_CONTROL=y
CONFIG_OF_LIBFDT=y
CONFIG_TIMER=y
CONFIG_DM_GPIO=y
CONFIG_DM_SERIAL=y

# ===== 强制禁用沙盒/仿真/ACPI类无用驱动（ARM架构下自动失效，双重保险） =====
# CONFIG_SANDBOX is not set
# CONFIG_USB_EMUL is not set
# CONFIG_I2C_EMUL is not set
# CONFIG_ACPI is not set
# CONFIG_ACPI_PMC is not set
# CONFIG_P2SB is not set
# CONFIG_VIRTIO_SANDBOX is not set
# CONFIG_TEST_DRV is not set
# CONFIG_SWAP_CASE is not set
# CONFIG_CMD_IO is not set

# ===== TPL 启动链配置 =====
CONFIG_TPL=y

# DDR / SPL / TPL 底层驱动基础（RK3528 DDR初始化必需）
CONFIG_SPL_DRIVERS_MISC=y
CONFIG_SPL_RAM_SUPPORT=y
CONFIG_TPL_DRIVERS_MISC=y

# MMC 环境变量（eMMC mmc0 存储）
CONFIG_ENV_IS_IN_MMC=y
CONFIG_SYS_MMC_ENV_DEV=0
CONFIG_ENV_SIZE=0x4000
CONFIG_ENV_OFFSET=0x3F0000
# 关键补充：SPL阶段MMC驱动，SPL才能识别eMMC
CONFIG_DM_MMC=y
CONFIG_SPL_DM_MMC=y
CONFIG_ROCKCHIP_MMC=y

# I2C 驱动（匹配DTS & SPL硬件枚举）
CONFIG_DM_I2C=y
CONFIG_SPL_DM_I2C=y
CONFIG_ROCKCHIP_I2C=y
