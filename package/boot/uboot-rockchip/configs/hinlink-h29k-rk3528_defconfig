# Hinlink H29K (RK3528) U-Boot defconfig
# OpenWrt 25.12 + Linux 6.12 | 对标generic-rk3528极简启动版

# ===== 架构核心配置 =====
CONFIG_ARM=y
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_SPL_64BIT=y
CONFIG_COUNTER_FREQUENCY=24000000
CONFIG_SKIP_LOWLEVEL_INIT=y
CONFIG_SUPPORT_TPL=y
CONFIG_TPL=y
CONFIG_ROCKCHIP_EXTERNAL_TPL=y

# ===== 平台与板级基础 =====
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ROCKCHIP_RK3528=y
CONFIG_DEFAULT_DEVICE_TREE="rockchip/rk3528-hinlink-h29k"
CONFIG_DEFAULT_FDT_FILE="rockchip/rk3528-hinlink-h29k.dtb"
CONFIG_SYS_LOAD_ADDR=0x08080000
CONFIG_TEXT_BASE=0x00200000

# ===== 串口（备用调试，不用可直接删除本段） =====
# CONFIG_DISPLAY_CPUINFO is not set
CONFIG_DEBUG_UART=y
CONFIG_DEBUG_UART_BASE=0xFF9F0000
CONFIG_DEBUG_UART_CLOCK=24000000
CONFIG_DEBUG_UART_SHIFT=2
CONFIG_BAUDRATE=1500000

# ===== 非必需功能关闭 =====
# CONFIG_OF_UPSTREAM is not set
# CONFIG_SPL_RAW_IMAGE_SUPPORT is not set
# CONFIG_DOS_PARTITION is not set

# ===== SPL 最小启动集（严格对标generic精简） =====
CONFIG_SUPPORT_SPL=y
CONFIG_SPL=y
CONFIG_SPL_MAX_SIZE=0x40000
CONFIG_SPL_DM=y
CONFIG_SPL_OF_CONTROL=y
CONFIG_SPL_OF_LIBFDT=y
CONFIG_OF_SPL_REMOVE_PROPS="clock-names interrupt-parent assigned-clocks assigned-clock-rates assigned-clock-parents"
CONFIG_SPL_LIBCOMMON_SUPPORT=y
CONFIG_SPL_LIBGENERIC_SUPPORT=y
CONFIG_SPL_PINCTRL=y
CONFIG_SPL_ROCKCHIP_BACK_TO_BROM=y
CONFIG_SPL_SERIAL=y
CONFIG_SPL_DM_SERIAL=y
CONFIG_SPL_FIT=y
CONFIG_SPL_LOAD_FIT=y
CONFIG_SPL_ATF=y
CONFIG_SPL_CLK=y
CONFIG_DM_MMC=y
CONFIG_SPL_MMC=y
CONFIG_SPL_DM_MMC=y
CONFIG_SPL_SYS_MALLOC_F_LEN=0x2000
CONFIG_SYS_NS16550_MEM32=y

# ===== 启动必需核心框架 =====
CONFIG_DM=y
CONFIG_OF_CONTROL=y
CONFIG_OF_LIBFDT=y
CONFIG_CLK=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_ROCKCHIP=y
CONFIG_RESET_ROCKCHIP=y
CONFIG_SYSRESET_ROCKCHIP=y
CONFIG_TIMER=y
CONFIG_ERRNO_STR=y

# ===== eMMC 存储（启动唯一必需外设） =====
CONFIG_MMC=y
CONFIG_SUPPORT_EMMC_RPMB=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_SDMA=y
CONFIG_MMC_SDHCI_ROCKCHIP=y
CONFIG_MMC_HS400_SUPPORT=y
CONFIG_SYS_MMC_MAX_BLK_COUNT=32768

# ===== 镜像打包与校验 =====
CONFIG_BINMAN=y
CONFIG_FIT=y
CONFIG_SHA256=y
CONFIG_SPL_HASH=y

# ===== MMC 环境变量 =====
CONFIG_ENV_IS_IN_MMC=y
CONFIG_SYS_MMC_ENV_DEV=0
CONFIG_ENV_SIZE=0x4000
CONFIG_ENV_OFFSET=0x3F0000

# ===== 文件系统（读取boot分区必需） =====
CONFIG_CMD_BOOTM=y
CONFIG_CMD_BOOTI=y
CONFIG_CMD_MMC=y
CONFIG_CMD_FAT=y
CONFIG_CMD_EXT4=y
CONFIG_CMD_FS_GENERIC=y
CONFIG_FS_FAT=y
CONFIG_FS_EXT4=y

# ===== 自动启动（零延迟，跳过命令行等待） =====
CONFIG_BOOTDELAY=0
CONFIG_AUTOBOOT=y

# ===== 早期内存池 =====
CONFIG_SYS_MALLOC_F_LEN=0x4000

# CONFIG_BOOTMETH_VBE is not set
# CONFIG_NET is not set
CONFIG_ROCKCHIP_GPIO=y
