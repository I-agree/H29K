# CONFIG_RNG_TURRIS_RWTM is not set
# CONFIG_RNG_EXYNOS is not set

# ===== 引导方式：禁用 BOOTSTD，使用传统脚本 =====
# CONFIG_BOOTSTD is not set

# ===== Shell 交互基础配置 =====
CONFIG_CMDLINE=y
CONFIG_HUSH_PARSER=y
CONFIG_CMDLINE_EDITING=y
CONFIG_AUTO_COMPLETE=y
CONFIG_SYS_LONGHELP=y
CONFIG_SYS_MAXARGS=64
CONFIG_CMDPROMPT="=> "
# CONFIG_SYS_XTRACE is not set

# ===== 环境变量命令 =====
CONFIG_CMD_EDITENV=y
# CONFIG_CMD_SAVEENV is not set
CONFIG_CMD_ERASEENV=y
CONFIG_CMD_EXPORTENV=y
CONFIG_CMD_IMPORTENV=y
CONFIG_CMD_ENV_EXISTS=y
CONFIG_CMD_NVEDIT_INFO=y
CONFIG_CMD_ENV=y

# ===== 核心启动命令（必须保留） =====
CONFIG_CMD_SOURCE=y
CONFIG_CMD_RUN=y
CONFIG_CMD_MMC=y
CONFIG_CMD_FS_GENERIC=y
CONFIG_CMD_EXT4=y
CONFIG_CMD_BOOTM=y
CONFIG_CMD_BOOTI=y
# CONFIG_CMD_BOOTZ is not set
CONFIG_CMD_FDT=y
CONFIG_CMD_GO=y
CONFIG_CMD_IMINFO=y
CONFIG_CMD_XIMG=y

# ===== 基础常用调试命令（精简保留最小集合） =====
CONFIG_CMD_ECHO=y
CONFIG_CMD_SETEXPR=y
CONFIG_CMD_ITEST=y
CONFIG_CMD_SLEEP=y
CONFIG_CMD_PAUSE=y
CONFIG_CMD_GPIO=y
CONFIG_CMD_MEMINFO=y
CONFIG_CMD_PART=y
CONFIG_CMD_GPT=y
CONFIG_CMD_FS_UUID=y
CONFIG_CMD_BDI=y
CONFIG_CMD_CONSOLE=y
CONFIG_CMD_HELP=y
CONFIG_CMD_HISTORY=y
CONFIG_CMD_MEMORY=y
CONFIG_CMD_CRC32=y
CONFIG_CMD_UNLZ4=y
CONFIG_CMD_UNZIP=y
CONFIG_CMD_LZMADEC=y
CONFIG_CMD_RNG=y

# ===== 量产精简：移除冗余调试命令 =====
# CONFIG_CMD_MEMINFO_MAP is not set
# CONFIG_CMD_MISC is not set
# CONFIG_CMD_RANDOM is not set

# ===== 控制台缓存 =====
CONFIG_CONSOLE_MUX=y
CONFIG_SYS_CONSOLE_IS_IN_ENV=y

# ===== 日志配置：量产下调为警告级别，关闭冗余 INFO 日志 =====
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=5
CONFIG_SPL_LOG=y
CONFIG_SPL_LOG_MAX_LEVEL=3

# ===== 关闭无关高级功能 =====
# CONFIG_BOOTMETH_VBE is not set
# CONFIG_DISPLAY_CPUINFO is not set
# CONFIG_ADC is not set
# CONFIG_DM_PWM is not set
# CONFIG_EFI_LOADER is not set

# ========== 官方标配优化项 ==========
CONFIG_DISPLAY_BOARDINFO_LATE=y
CONFIG_ENV_RELOC_GD_ENV_ADDR=y

# ========== bloblist 底层框架+查看命令 =========
CONFIG_BLOBLIST=y
CONFIG_CMD_BLOBLIST=y

# ========== 内存布局传递、内核防内存踩踏 =========
CONFIG_FDT_MEM_RESERVE=y
CONFIG_BOOTM_FDT_RELOC=y

# ========== 内核镜像完整性校验 ==========
CONFIG_BOOTM_IMAGE_CRC=y

# ========== 随机硬件标识防冲突 ==========
CONFIG_SETENV_RANDOM=y
CONFIG_RANDOM=y
CONFIG_SPL_RANDOM=y

# ===== 倒计时一秒钟 =====
CONFIG_BOOTDELAY=1
