stdout=serial
stdin=serial
stderr=serial
bootcmd=mmc dev 0; load mmc 0:1 ${scriptaddr} boot.scr; source ${scriptaddr}
scriptaddr=0xc0200000
kernel_addr_r=0xc0080000
fdt_addr_r=0xc4000000
ramdisk_addr_r=0xc5000000
bootargs=root=/dev/mmcblk0p2 rootfstype=ext4 rootwait rw console=ttyS2,1500000n8 earlycon
