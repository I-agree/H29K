soc=rk3528
devtype=mmc
kernel_addr_r=0xc0080000
serial_port=ttyS0
serial_addr=,0xff9f0000
boot_openwrt=part uuid ${devtype} ${devnum}:2 uuid;setenv bootargs console=${serial_port},1500000 earlycon=uart8250,mmio32${serial_addr} root=PARTUUID=${uuid} rw rootwait cma=256M swiotlb=1024 coherent_pool=2M panic=10;load ${devtype} ${devnum}:1 ${kernel_addr_r} kernel.img && setenv kernel_size ${filesize} && bootm ${kernel_addr_r}
bootcmd=run boot_openwrt
