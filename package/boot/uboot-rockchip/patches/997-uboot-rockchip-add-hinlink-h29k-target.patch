From: OpenWrt Port
Subject: [PATCH] uboot-rockchip: add HINLINK H29K board target

Add U-Boot build target for the HINLINK H29K single board computer
based on the RK3528 SoC.

---
 package/boot/uboot-rockchip | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/package/boot/uboot-rockchip/Makefile b/package/boot/uboot-rockchip/Makefile
--- a/package/boot/uboot-rockchip/Makefile
+++ b/package/boot/uboot-rockchip/Makefile
@@ -184,7 +184,14 @@
 define U-Boot/hinlink-h28k-rk3528
   $(U-Boot/rk3528/Default)
   NAME:=HINLINK H28K
   BUILD_DEVICES:= \
     hinlink_h28k
 endef
 
+define U-Boot/hinlink-h29k-rk3528
+  $(U-Boot/rk3528/Default)
+  NAME:=HINLINK H29K
+  BUILD_DEVICES:= \
+    hinlink_h29k
+endef
+
 define U-Boot/radxa-e20c-rk3528
@@ -437,4 +444,5 @@
   rock-pi-e-v3-rk3328 \
   hinlink-h28k-rk3528 \
+  hinlink-h29k-rk3528 \
   radxa-e20c-rk3528 \
   rock-2-rk3528 \
