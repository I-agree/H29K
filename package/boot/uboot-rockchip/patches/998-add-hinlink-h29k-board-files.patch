From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: aaa aaa <aaaaaaa@aaa.edu.cn>
Date: Wed, 3 Dec 2026 20:03:22 +0800
Subject: [PATCH] board: hinlink: add HINLINK H29K board support

Add board support files for the HINLINK H29K single board computer
based on the RK3528 SoC, including vendor Kconfig, board Kconfig,
Makefile, board init code and default environment script.

Signed-off-by: aaa aaa <aaaaaaa@aaa.edu.cn>
---
 board/hinlink/Kconfig       | 11 ++++++++
 board/hinlink/h29k/Kconfig  | 18 +++++++++++++
 board/hinlink/h29k/Makefile |  5 +++++
 board/hinlink/h29k/board.c  | 12 ++++++++++
 board/hinlink/h29k/h29k.env |  6 ++++++++++
 5 files changed, 52 insertions(+)

--- /dev/null
+++ b/board/hinlink/Kconfig
@@ -0,0 +1,11 @@
+# SPDX-License-Identifier: GPL-2.0+
+config VENDOR_HINLINK
+	bool
+	help
+	  Selected when any Hinlink board is enabled.
+
+if VENDOR_HINLINK
+
+source "board/hinlink/h29k/Kconfig"
+
+endif
--- /dev/null
+++ b/board/hinlink/h29k/Kconfig
@@ -0,0 +1,18 @@
+# SPDX-License-Identifier: GPL-2.0+
+config TARGET_HINLINK_H29K
+	bool "Hinlink H29K RK3528 Board"
+	select VENDOR_HINLINK
+	select ARCH_ROCKCHIP
+
+if TARGET_HINLINK_H29K
+
+config SYS_VENDOR
+	default "hinlink"
+
+config SYS_BOARD
+	default "h29k"
+
+config SYS_CONFIG_NAME
+	default "hinlink-h29k-rk3528"
+
+endif
--- /dev/null
+++ b/board/hinlink/h29k/Makefile
@@ -0,0 +1,5 @@
+# SPDX-License-Identifier: GPL-2.0+
+#
+# (C) Copyright 2026 Hinlink
+#
+obj-y := board.o
--- /dev/null
+++ b/board/hinlink/h29k/board.c
@@ -0,0 +1,12 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Board init for Hinlink H29K RK3528
+ */
+#include <asm/global_data.h>
+
+DECLARE_GLOBAL_DATA_PTR;
+
+int board_init(void)
+{
+	return 0;
+}
--- /dev/null
+++ b/board/hinlink/h29k/h29k.env
@@ -0,0 +1,6 @@
+soc=rk3528
+devtype=mmc
+devnum=0
+kernel_addr_r=0xc00800
+bootdelay=0
+bootcmd=part uuid ${devtype} ${devnum}:2 uuid; if test $soc = rk3308; then serial_addr=,0xff0c0000; serial_port=ttyS2; elif test $soc = rk3328; then serial_addr=,0xff130000; serial_port=ttyS2; elif test $soc = rk3399; then serial_addr=,0xff1a0000; serial_port=ttyS2; elif test $soc = rk3528; then serial_addr=,0xff9f0000; serial_port=ttyS0; elif test $soc = rk3568; then serial_addr=,0xfe660000; serial_port=ttyS2; elif test $soc = rk3576; then serial_addr=,0x2ad40000; serial_port=ttyS0; elif test $soc = rk3588; then serial_addr=,0xfeb50000; serial_port=ttyS2; fi; setenv bootargs console=${serial_port},1500000 earlycon=uart8250,mmio32${serial_addr} root=PARTUUID=${uuid} rw rootwait; load ${devtype} ${devnum}:1 ${kernel_addr_r} kernel.img; bootm ${kernel_addr_r}
