From: OpenWrt Port
Subject: [PATCH] Makefile: fix $< expanding to FORCE for env generated headers

Fix two build failures caused by $< resolving to the FORCE phony target,
triggering "cannot open FORCE: No such file" shell errors:

1. For $(env_h): explicitly append FORCE at the end of the dependency list
   to ensure include/generated/env.in is always the first prerequisite.

2. For $(defaultenv_h): add a /dev/null fallback when
   CONFIG_ENV_DEFAULT_ENV_TEXT_FILE is unset, preventing FORCE from
   becoming the first dependency when the config option is empty.
---
 Makefile | 2 +-
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Makefile b/Makefile
--- a/Makefile
+++ b/Makefile
@@ -2103,8 +2103,8 @@
 # Write out the resulting environment, converted to a C string
 quiet_cmd_gen_envt = ENVT    $@
       cmd_gen_envt = \
	awk -f $(srctree)/scripts/env2string.awk $< >$@
-$(env_h): include/generated/env.in
+$(env_h): include/generated/env.in FORCE
	$(call cmd,gen_envt)
 
 # ---------------------------------------------------------------------------
@@ -2281,7 +2281,7 @@
 $(dt_h): $(srctree)/Makefile FORCE
 	$(call filechk,dt.h)
 
-$(defaultenv_h): $(CONFIG_ENV_DEFAULT_ENV_TEXT_FILE:"%"=%) FORCE
+$(defaultenv_h): $(if $(CONFIG_ENV_DEFAULT_ENV_TEXT_FILE:"%"=%),$(CONFIG_ENV_DEFAULT_ENV_TEXT_FILE:"%"=%),/dev/null) FORCE
 	$(call filechk,defaultenv.h)
 
 # ---------------------------------------------------------------------------
