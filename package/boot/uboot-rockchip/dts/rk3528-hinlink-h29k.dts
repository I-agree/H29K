// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
/*
 * U-Boot 2025.10 DTS for HINLINK H29K (RK3528)
 * Fully aligned with upstream rk3528.dtsi & rk3528-pinctrl.dtsi
 */

/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include "rk3528.dtsi"

/ {
	model = "HINLINK H29K";
	compatible = "hinlink,h29k", "rockchip,rk3528";

	aliases {
		mmc0 = &sdhci;
		mmc1 = &sdmmc;
		spi0 = &sfc;
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:1500000n8";
	};

	/*
	 * 上游 rk3528.dtsi 缺失 Combo PHY 节点
	 * 在此显式定义并打上 combphy 标签供 U-Boot 使用
	 */
	combphy: phy@ffdc0000 {
		compatible = "rockchip,rk3528-naneng-combphy";
		reg = <0x0 0xffdc0000 0x0 0x100>;
		#phy-cells = <1>;
		status = "okay";
		bootph-pre-ram;
	};

	vcc5v0_sys: regulator-5v0-vcc-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-always-on;
		regulator-boot-on;
		bootph-all;
	};

	vcc_3v3: regulator-3v3-vcc {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc5v0_sys>;
		bootph-all;
	};

	vcc_1v8: regulator-1v8-vcc {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_3v3>;
		bootph-all;
	};

	/*
	 * 修正：上游 pinctrl 无 sdmmc_pwren_l 标签
	 * 直接使用上游定义的 sdmmc_pwren (GPIO4_A1)
	 */
	vcc3v3_sd: regulator-3v3-vcc-sd {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_sd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio4 RK_PA1 GPIO_ACTIVE_LOW>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_3v3>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc_pwren>;
		bootph-all;
	};

	/*
	 * 修正：上游 pinctrl 无 sdmmc_vol_ctrl_h 标签
	 * regulator-gpio 直接使用原生 GPIO 引用即可
	 */
	vccio_sd: regulator-vccio-sd {
		compatible = "regulator-gpio";
		regulator-name = "vccio_sd";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <3300000>;
		gpios = <&gpio4 RK_PB6 GPIO_ACTIVE_HIGH>;
		states = <1800000 0x0>, <3300000 0x1>;
		startup-delay-us = <2000>;
		vin-supply = <&vcc5v0_sys>;
		bootph-all;
	};

	/*
	 * 上游 rk3528.dtsi 缺失 SFC 节点
	 * 在板级 DTS 中完整定义，已移除不存在的 power-domains 引用
	 */
	sfc: spi@ffc00000 {
		compatible = "rockchip,sfc";
		reg = <0x0 0xffc00000 0x0 0x4000>;
		interrupts = <GIC_SPI 135 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&cru SCLK_SFC>, <&cru HCLK_SFC>;
		clock-names = "clk_sfc", "hclk_sfc";
		assigned-clocks = <&cru SCLK_SFC>;
		assigned-clock-rates = <100000000>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";
		pinctrl-names = "default";
		pinctrl-0 = <&fspi_pins>;
		bootph-all;

		sfc_flash0: flash@0 {
			compatible = "jedec,spi-nor";
			reg = <0>;
			spi-max-frequency = <24000000>;
			spi-rx-bus-width = <4>;
			spi-tx-bus-width = <4>;
			bootph-all;
		};
	};
};

&sdhci {
	bus-width = <8>;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
	non-removable;
	vmmc-supply = <&vcc_3v3>;
	vqmmc-supply = <&vcc_1v8>;
	pinctrl-names = "default";
	pinctrl-0 = <&emmc_bus8 &emmc_clk &emmc_cmd &emmc_strb>;
	status = "okay";
	bootph-all;
};

&sdmmc {
	bus-width = <4>;
	cap-sd-highspeed;
	disable-wp;
	max-frequency = <150000000>;
	rockchip,default-sample-phase = <90>;
	sd-uhs-sdr104;
	vmmc-supply = <&vcc3v3_sd>;
	vqmmc-supply = <&vccio_sd>;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_bus4 &sdmmc_clk &sdmmc_cmd &sdmmc_det>;
	status = "okay";
	bootph-all;
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0m0_xfer>;
	status = "okay";
	bootph-all;
};

&gmac1 {
	clock_in_out = "output";
	phy-handle = <&rgmii_phy>;
	local-mac-address = [D0 92 FC 25 AC C8];
	tx_delay = <0x3>;
	rx_delay = <0x6>;
	phy-supply = <&vcc_3v3>;
	pinctrl-names = "default";
	pinctrl-0 = <&rgmii_miim &rgmii_tx_bus2 &rgmii_rx_bus2
		     &rgmii_rgmii_clk &rgmii_rgmii_bus>;
	status = "okay";
	bootph-pre-ram;
};

&mdio1 {
	rgmii_phy: ethernet-phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x1>;
		reset-assert-us = <20000>;
		reset-deassert-us = <100000>;
		reset-gpios = <&gpio4 RK_PC2 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&gmac1_rstn_l>;
		bootph-pre-ram;
	};
};

&combphy {
	status = "okay";
	bootph-pre-ram;
};

&pinctrl {
	bootph-all;

	/*
	 * GMAC1 复位引脚：上游 pinctrl 未定义，必须在板级声明
	 */
	gmac {
		gmac1_rstn_l: gmac1-rstn-l {
			rockchip,pins = <4 RK_PC2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};
