/*
 * U-Boot overlay for HINLINK H29K
 * Auto-included by U-Boot build system.
 * Place additional U-Boot specific overrides here.
 */

/* 如果主线 rk3528-u-boot.dtsi 已包含 bootph-all，
 * 此处仅需补充板级特有覆盖 */

&gpio0 {
	bootph-all;
};

&gpio1 {
	bootph-all;
};

&gpio4 {
	bootph-all;
};

/* 确保 eMMC 供电 regulator 在 SPL 阶段可见 */
&vcc5v0_sys {
	bootph-all;
};

&vcc_3v3 {
	bootph-all;
};

&vcc_1v8 {
	bootph-all;
};

&vcc3v3_sd {
	bootph-all;
};

&vdd_arm {
	bootph-all;
};

&vdd_logic {
	bootph-all;
};
