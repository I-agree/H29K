/ {
    chosen {
        tick-timer = &timer0; 
    };
};

&spi1 {
    status = "disabled";
};

&i2c1 {
    status = "disabled";
};

&pinctrl {
    u-boot,dm-pre-reloc;
};

&vcc_3v3 {
    u-boot,dm-pre-reloc;
};

&vcc3v3_sd {
    u-boot,dm-pre-reloc;
};

&sdhci {
    u-boot,dm-pre-reloc;
};

&sdmmc {
    u-boot,dm-pre-reloc;
};

&uart0 {
    u-boot,dm-pre-reloc;
};
