/*
 * U-Boot overlay for HINLINK H29K
 * Auto-included by U-Boot build system.
 * Place additional U-Boot specific overrides here.
 */

/* 仅启用硬件实际用到的GPIO组 */
&gpio1 {
	bootph-all;
};

&gpio4 {
	bootph-all;
};

/* IOC引脚复用寄存器，SPL必须早期初始化 */
&ioc_grf {
	bootph-all;
};

/* SPL阶段预初始化核心供电，保证存储、DDR稳定上电 */
&vcc5v0_sys {
	bootph-all;
};

&vcc_3v3 {
	bootph-all;
};

&vcc_1v8 {
	bootph-all;
};

&vcc3v3_sd {
	bootph-all;
};

&vdd_arm {
	bootph-all;
};

&vdd_logic {
	bootph-all;
};
