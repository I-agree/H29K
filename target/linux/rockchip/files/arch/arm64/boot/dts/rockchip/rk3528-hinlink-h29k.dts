/dts-v1/;

/ {
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;
	model = "HINLINK H29K";
	compatible = "hinlink,h29k", "rockchip,rk3528";

	aliases {
		gpio0 = &gpio0;
		gpio1 = &gpio1;
		gpio2 = &gpio2;
		gpio3 = &gpio3;
		gpio4 = &gpio4;
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c4;
		i2c5 = &i2c5;
		i2c6 = &i2c6;
		i2c7 = &i2c7;
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
		serial4 = &uart4;
		serial5 = &uart5;
		serial6 = &uart6;
		serial7 = &uart7;
		spi0 = &spi0;
		spi1 = &spi1;
		spi2 = &sfc;
		mmc0 = &sdhci;
		mmc1 = &sdmmc3;
		mmc2 = &sdmmc2;
		ethernet0 = &gmac1;
		led-boot = &led_work;
		led-failsafe = &led_work;
		led-running = &led_work;
		led-upgrade = &led_work;
	};

	cpus {
		#address-cells = <2>;
		#size-cells = <0>;

		cpu-map {
			cluster0 {
				core0 { cpu = <&cpu0>; };
				core1 { cpu = <&cpu1>; };
				core2 { cpu = <&cpu2>; };
				core3 { cpu = <&cpu3>; };
			};
		};

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x00>;
			clocks = <&scmi_clk 0x15>;
			assigned-clocks = <&scmi_clk 0x15>;
			assigned-clock-rates = <1200000000>;
			dynamic-power-coefficient = <147>;
			#cooling-cells = <2>;
			enable-method = "psci";
			operating-points-v2 = <&cpu_opp_table>;
			cpu-supply = <&vdd_arm>;
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x01>;
			clocks = <&scmi_clk 0x15>;
			dynamic-power-coefficient = <147>;
			#cooling-cells = <2>;
			enable-method = "psci";
			operating-points-v2 = <&cpu_opp_table>;
			cpu-supply = <&vdd_arm>;
		};

		cpu2: cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x02>;
			clocks = <&scmi_clk 0x15>;
			dynamic-power-coefficient = <147>;
			#cooling-cells = <2>;
			enable-method = "psci";
			operating-points-v2 = <&cpu_opp_table>;
			cpu-supply = <&vdd_arm>;
		};

		cpu3: cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x03>;
			clocks = <&scmi_clk 0x15>;
			dynamic-power-coefficient = <147>;
			#cooling-cells = <2>;
			enable-method = "psci";
			operating-points-v2 = <&cpu_opp_table>;
			cpu-supply = <&vdd_arm>;
		};
	};

	cpu_opp_table: opp-table-0 {
		compatible = "operating-points-v2";
		opp-shared;

		opp-408000000 {
			opp-hz = <0x00 408000000>;
			opp-microvolt = <825000 825000 1100000>;
			clock-latency-ns = <40000>;
			opp-suspend;
		};
		opp-600000000 {
			opp-hz = <0x00 600000000>;
			opp-microvolt = <825000 825000 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-816000000 {
			opp-hz = <0x00 816000000>;
			opp-microvolt = <825000 825000 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-1008000000 {
			opp-hz = <0x00 1008000000>;
			opp-microvolt = <825000 825000 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-1200000000 {
			opp-hz = <0x00 1200000000>;
			opp-microvolt = <825000 825000 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-1416000000 {
			opp-hz = <0x00 1416000000>;
			opp-microvolt = <962500 962500 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-1608000000 {
			opp-hz = <0x00 1608000000>;
			opp-microvolt = <1012500 1012500 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-1800000000 {
			opp-hz = <0x00 1800000000>;
			opp-microvolt = <1062500 1062500 1100000>;
			clock-latency-ns = <40000>;
		};
		opp-2016000000 {
			opp-hz = <0x00 2016000000>;
			opp-microvolt = <1100000 1100000 1100000>;
			clock-latency-ns = <40000>;
		};
	};

	arm-pmu {
		compatible = "arm,cortex-a53-pmu";
		interrupts = <0 171 4  0 172 4  0 173 4  0 174 4>;
		interrupt-affinity = <&cpu0 &cpu1 &cpu2 &cpu3>;
	};

	firmware {
		scmi {
			compatible = "arm,scmi-smc";
			arm,smc-id = <0x82000010>;
			shmem = <&scmi_shmem>;
			#address-cells = <1>;
			#size-cells = <0>;

			scmi_clk: protocol@14 {
				reg = <0x14>;
				#clock-cells = <1>;
			};
		};
	};

	gpu_opp_table: gpu-opp-table {
		compatible = "operating-points-v2";

		opp-300000000 {
			opp-hz = <0x00 300000000>;
			opp-microvolt = <875000 875000 1000000>;
		};
		opp-500000000 {
			opp-hz = <0x00 500000000>;
			opp-microvolt = <875000 875000 1000000>;
		};
		opp-600000000 {
			opp-hz = <0x00 600000000>;
			opp-microvolt = <875000 875000 1000000>;
		};
		opp-700000000 {
			opp-hz = <0x00 700000000>;
			opp-microvolt = <900000 900000 1000000>;
		};
		opp-800000000 {
			opp-hz = <0x00 800000000>;
			opp-microvolt = <950000 950000 1000000>;
		};
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		scmi_shmem: shmem@10f000 {
			compatible = "arm,scmi-shmem";
			reg = <0x00 0x10f000 0x00 0x100>;
			no-map;
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <1 13 0xf08  1 14 0xf08  1 11 0xf08  1 10 0xf08>;
	};

	xin24m {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <24000000>;
		clock-output-names = "xin24m";
	};

	pcie: pcie@fe4f0000 {
		compatible = "rockchip,rk3528-pcie", "rockchip,rk3568-pcie";
		reg = <0x00 0xfe000000 0x00 0x400000
		       0x00 0xfe4f0000 0x00 0x10000
		       0x00 0xfc000000 0x00 0x100000>;
		reg-names = "dbi", "apb", "config";
		interrupts = <0 158 4  0 157 4  0 156 4  0 155 4  0 154 4  0 153 4>;
		interrupt-names = "msi", "pmc", "sys", "legacy", "msg", "err";
		bus-range = <0x00 0xff>;
		clocks = <&cru 0xd9  &cru 0xda  &cru 0xdb  &cru 0x9e  &cru 0xd8  &cru 0xd7  &cru 0xdc>;
		clock-names = "aclk", "hclk_slv", "hclk_dbi", "pclk_cru", "aux", "pclk", "pipe";
		device_type = "pci";
		#interrupt-cells = <1>;
		interrupt-map-mask = <0 0 0 7>;
		interrupt-map = <0 0 0 1 &pcie_irq 0
				0 0 0 2 &pcie_irq 1
				0 0 0 3 &pcie_irq 2
				0 0 0 4 &pcie_irq 3>;
		linux,pci-domain = <0>;
		max-link-speed = <2>;
		num-ib-windows = <8>;
		num-ob-windows = <8>;
		num-viewport = <4>;
		num-lanes = <1>;
		phys = <&combphy 2>;
		phy-names = "pcie-phy";
		ranges = <0x1000000 0 0xfc100000 0 0xfc100000 0 0x100000
			  0x2000000 0 0xfc200000 0 0xfc200000 0 0x1e00000
			  0x3000000 1 0x00 1 0x00 0x40000000>;
		resets = <&cru 0x1e3  &cru 0x1e1  &cru 0x19b>;
		reset-names = "pwr", "periph", "preset_cru";
		#address-cells = <3>;
		#size-cells = <2>;
		status = "disabled";

		pcie_irq: legacy-interrupt-controller {
			#address-cells = <0>;
			#interrupt-cells = <1>;
			interrupt-controller;
			interrupt-parent = <&gic>;
			interrupts = <0 155 1>;
		};
	};

	usbdrd_dwc3: usb@fe500000 {
		compatible = "rockchip,rk3528-dwc3", "snps,dwc3";
		reg = <0x00 0xfe500000 0x00 0x400000>;
		interrupts = <0 152 4>;
		clocks = <&cru 0x106  &cru 0x107  &cru 0x105>;
		clock-names = "ref_clk", "suspend_clk", "bus_clk";
		dr_mode = "otg";
		phys = <&usb2phy0_otg>, <&combphy 4>;
		phy-names = "usb2-phy", "usb3-phy";
		phy_type = "utmi_wide";
		snps,dis-del-phy-power-chg-quirk;
		snps,dis-tx-ipgap-linecheck-quirk;
		snps,dis-u2-freeclk-exists-quirk;
		snps,dis_enblslpm_quirk;
		snps,dis_u2_susphy_quirk;
		resets = <&cru 0x211>;
		reset-names = "usb3-otg";
		status = "okay";
	};

	gic: interrupt-controller@fed01000 {
		compatible = "arm,gic-400";
		#interrupt-cells = <3>;
		#address-cells = <0>;
		interrupt-controller;
		reg = <0x00 0xfed01000 0x00 0x1000
		       0x00 0xfed02000 0x00 0x2000
		       0x00 0xfed04000 0x00 0x2000
		       0x00 0xfed06000 0x00 0x2000>;
		interrupts = <1 9 0xf08>;
	};

	usb_host0_ehci: usb@ff100000 {
		compatible = "generic-ehci";
		reg = <0x00 0xff100000 0x00 0x40000>;
		interrupts = <0 143 4>;
		clocks = <&cru 0x1a0  &cru 0x1a1  &usb2phy0>;
		clock-names = "usbhost", "arbiter", "utmi";
		phys = <&usb2phy0_host>;
		phy-names = "usb2-phy";
		status = "okay";
	};

	usb_host0_ohci: usb@ff140000 {
		compatible = "generic-ohci";
		reg = <0x00 0xff140000 0x00 0x40000>;
		interrupts = <0 144 4>;
		clocks = <&cru 0x1a0  &cru 0x1a1  &usb2phy0>;
		clock-names = "usbhost", "arbiter", "utmi";
		phys = <&usb2phy0_host>;
		phy-names = "usb2-phy";
		status = "okay";
	};

	/* QOS 节点全量保留 */
	qos@ff200000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200000 0x00 0x20>;
	};
	qos@ff200080 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200080 0x00 0x20>;
	};
	qos@ff200100 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200100 0x00 0x20>;
	};
	qos@ff200200 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200200 0x00 0x20>;
	};
	qos@ff200280 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200280 0x00 0x20>;
	};
	qos@ff200300 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200300 0x00 0x20>;
	};
	qos@ff200380 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff200380 0x00 0x20>;
	};
	qos@ff210000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff210000 0x00 0x20>;
	};
	qos@ff210080 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff210080 0x00 0x20>;
	};
	qos@ff220000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff220000 0x00 0x20>;
	};
	qos@ff220080 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff220080 0x00 0x20>;
	};
	qos@ff240000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff240000 0x00 0x20>;
	};
	qos@ff250000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff250000 0x00 0x20>;
	};
	qos@ff260000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff260000 0x00 0x20>;
	};
	qos@ff270000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270000 0x00 0x20>;
	};
	qos@ff270080 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270080 0x00 0x20>;
	};
	qos@ff270100 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270100 0x00 0x20>;
	};
	qos@ff270200 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270200 0x00 0x20>;
	};
	qos@ff270280 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270280 0x00 0x20>;
	};
	qos@ff270300 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270300 0x00 0x20>;
	};
	qos@ff270380 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270380 0x00 0x20>;
	};
	qos@ff270480 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270480 0x00 0x20>;
	};
	qos@ff270500 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff270500 0x00 0x20>;
	};
	qos@ff280000 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280000 0x00 0x20>;
	};
	qos@ff280080 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280080 0x00 0x20>;
	};
	qos@ff280100 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280100 0x00 0x20>;
	};
	qos@ff280180 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280180 0x00 0x20>;
	};
	qos@ff280200 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280200 0x00 0x20>;
	};
	qos@ff280280 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280280 0x00 0x20>;
	};
	qos@ff280300 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280300 0x00 0x20>;
	};
	qos@ff280380 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280380 0x00 0x20>;
	};
	qos@ff280400 {
		compatible = "rockchip,rk3528-qos", "syscon";
		reg = <0x00 0xff280400 0x00 0x20>;
	};

	grf: syscon@ff300000 {
		compatible = "rockchip,rk3528-grf", "syscon", "simple-mfd";
		reg = <0x00 0xff300000 0x00 0x90000>;

		grf_cru: grf-clock-controller {
			compatible = "rockchip,rk3528-grf-cru";
			#clock-cells = <1>;
		};

		reboot-mode {
			compatible = "syscon-reboot-mode";
			offset = <0x70200>;
			mode-bootloader = <0x5242c301>;
			mode-fastboot = <0x5242c309>;
			mode-loader = <0x5242c301>;
			mode-normal = <0x5242c300>;
			mode-recovery = <0x5242c303>;
		};
	};

	cru: clock-controller@ff4a0000 {
		compatible = "rockchip,rk3528-cru";
		reg = <0x00 0xff4a0000 0x00 0x30000>;
		rockchip,grf = <&grf>;
		#clock-cells = <1>;
		#reset-cells = <1>;
		assigned-clocks = <
			&cru 0x1ff &cru 0x03 &cru 0x04 &cru 0x02 &cru 0x0d
			&cru 0x11 &cru 0x09 &cru 0x0a &cru 0x0b &cru 0x0c
			&cru 0x0e &cru 0x0f &cru 0x10 &cru 0x12 &cru 0x90
			&cru 0x8f &cru 0x95 &cru 0x55 &cru 0x144 &cru 0x96
			&cru 0x93
		>;
		assigned-clock-rates = <
			32768 1188000000 1000000000 996000000 250000000
			500000000 50000000 100000000 150000000 200000000
			300000000 340000000 400000000 600000000 50000000
			100000000 125000000 500000000 340000000 300000000
			200000000
		>;
	};

	ioc_grf: syscon@ff540000 {
		compatible = "rockchip,rk3528-ioc-grf", "syscon";
		reg = <0x00 0xff540000 0x00 0x40000>;
	};

	pmu: power-management@ff600000 {
		compatible = "rockchip,rk3528-pmu", "syscon", "simple-mfd";
		reg = <0x00 0xff600000 0x00 0x2000>;

		power-controller {
			compatible = "rockchip,rk3528-power-controller";
			#power-domain-cells = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			pd_gpu@4 {
				reg = <4>;
				clocks = <&cru 0x113  &cru 0x10e>;
				pm_qos = <&qos_gpu0 &qos_gpu1>;
			};
			pd_rkvdec@5 { reg = <5>; };
			pd_rkvenc@6 { reg = <6>; };
			pd_vo@7 { reg = <7>; };
			pd_vpu@8 { reg = <8>; };
		};
	};

	mailbox@ff630000 {
		compatible = "rockchip,rk3528-mailbox", "rockchip,rk3368-mailbox";
		reg = <0x00 0xff630000 0x00 0x200>;
		interrupts = <0 60 4>;
		clocks = <&cru 0x20a>;
		clock-names = "pclk_mailbox";
		#mbox-cells = <1>;
		status = "disabled";
	};

	gpu: gpu@ff700000 {
		compatible = "rockchip,rk3528-mali", "arm,mali-450";
		reg = <0x00 0xff700000 0x00 0x40000>;
		interrupts = <0 88 4  0 89 4  0 86 4  0 92 4  0 93 4  0 90 4  0 91 4>;
		interrupt-names = "gp", "gpmmu", "pp", "pp0", "ppmmu0", "pp1", "ppmmu1";
		clocks = <&cru 0x113  &cru 0x10e>;
		clock-names = "bus", "core";
		assigned-clocks = <&scmi_clk 0x16>;
		assigned-clock-rates = <300000000>;
		power-domains = <&pmu_power 4>;
		operating-points-v2 = <&gpu_opp_table>;
		rockchip,grf = <&grf>;
		#cooling-cells = <2>;
		status = "okay";
		mali-supply = <&vdd_logic>;
	};

	spi0: spi@ff9c0000 {
		compatible = "rockchip,rk3528-spi", "rockchip,rk3066-spi";
		reg = <0x00 0xff9c0000 0x00 0x1000>;
		interrupts = <0 131 4>;
		#address-cells = <1>;
		#size-cells = <0>;
		clocks = <&cru 0x12a  &cru 0x129  &cru 0x12b>;
		clock-names = "spiclk", "apb_pclk", "sclk_in";
		dmas = <&dmac 0x19  &dmac 0x18>;
		dma-names = "tx", "rx";
		pinctrl-names = "default";
		pinctrl-0 = <&spi0_csn0 &spi0_csn1 &spi0_pins>;
		status = "disabled";
	};

	spi1: spi@ff9d0000 {
		compatible = "rockchip,rk3528-spi", "rockchip,rk3066-spi";
		reg = <0x00 0xff9d0000 0x00 0x1000>;
		interrupts = <0 132 4>;
		#address-cells = <1>;
		#size-cells = <0>;
		clocks = <&cru 0xbe  &cru 0xbd  &cru 0xbf>;
		clock-names = "spiclk", "apb_pclk", "sclk_in";
		dmas = <&dmac 0x1f  &dmac 0x1e>;
		dma-names = "tx", "rx";
		pinctrl-names = "default";
		pinctrl-0 = <&spi1_clk_miso &lcd_backlight_pin>;
		status = "okay";
		assigned-clocks = <&cru 0xbe>;
		assigned-clock-rates = <100000000>;
		num-cs = <1>;

		panel@0 {
			compatible = "sitronix,gc9307";
			reg = <0>;
			power-supply = <&vcc_3v3_lcd>;
			pinctrl-names = "default";
			pinctrl-0 = <&lcd_dc_pin>;
			dc-gpios = <&gpio1 12 0>;
			backlight-gpios = <&gpio0 0 1>;
			spi-max-frequency = <6000000>;
			width = <172>;
			height = <320>;
			buswidth = <8>;
			rotate = <270>;
			debug = <0>;
			spi-cpol;
			spi-cpha;
		};
		panel@2 {
			compatible = "sitronix,st7789v";
			reg = <2>;
			power-supply = <&vcc_3v3_lcd>;
			pinctrl-names = "default";
			pinctrl-0 = <&lcd_dc_pin>;
			dc-gpios = <&gpio1 12 0>;
			backlight-gpios = <&gpio0 0 1>;
			spi-max-frequency = <6000000>;
			width = <135>;
			height = <240>;
			buswidth = <8>;
			rotate = <270>;
			debug = <0>;
