/dts-v1/;

#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pwm/pwm.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/clock/rockchip,rk3528-cru.h>
#include <dt-bindings/power/rockchip,rk3528-power.h>
#include "rk3528.dtsi"

/ {
	model = "HINLINK H29K";
	compatible = "hinlink,h29k", "rockchip,rk3528";

	aliases {
		ethernet0 = &gmac1;
		mmc0 = &sdhci;
		mmc1 = &sdmmc;
		mmc2 = &sdio0;
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;

		led-boot = &led_work;
		led-failsafe = &led_work;
		led-running = &led_work;
		led-upgrade = &led_work;
	};

	chosen {
		stdout-path = "serial0:1500000n8";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		/* HDMI 专用 early framebuffer (1080p)，与 SPI 小屏无关 */
		framebuffer: framebuffer@90000000 {
			compatible = "simple-framebuffer";
			reg = <0x0 0x90000000 0x0 0x00800000>;
			width = <1920>;
			height = <1080>;
			stride = <7680>;
			format = "a8r8g8b8";
			clocks = <&cru ACLK_VOP>, <&cru PCLK_HDMI>;
			status = "disabled";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&key_reset_pin>;

		key-reset {
			label = "reset";
			gpios = <&gpio4 RK_PC1 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <20>;
		};
	};

	ir-receiver {
		compatible = "gpio-ir-receiver";
		gpios = <&gpio4 RK_PC6 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&ir_int_pin>;
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&led_4g_en>, <&led_5g_en>, <&led_work_en>;

		led_4g: led-4g {
			label = "red:modem_4g";
			gpios = <&gpio4 RK_PC0 GPIO_ACTIVE_LOW>;
		};

		led_5g: led-5g {
			label = "blue:modem_5g";
			gpios = <&gpio4 RK_PC3 GPIO_ACTIVE_LOW>;
		};

		led_work: led-work {
			label = "green:work";
			gpios = <&gpio4 RK_PB7 GPIO_ACTIVE_LOW>;
		};
	};

	/* PWM6 → SPI 小屏背光 (原厂 pwm@ffa98020) */
	backlight_lcd: backlight-lcd {
		compatible = "pwm-backlight";
		pwms = <&pwm6 0 25000 0>;
		brightness-levels = <
			  0  20  40  60  80 100
			120 140 160 180 200 220 240 255
		>;
		default-brightness-level = <6>;
		power-supply = <&vcc_3v3_lcd>;
		enable-gpios = <&gpio0 RK_PA1 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&lcd_bl_pin>;
	};

	rfkill-modem {
		compatible = "rfkill-gpio";
		label = "rfkill-modem";
		radio-type = "wwan";
		shutdown-gpios = <&gpio4 RK_PB4 GPIO_ACTIVE_LOW>;
	};

	sdio_pwrseq: sdio-pwrseq {
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <&wifi_reg_on>;
		post-power-on-delay-ms = <100>;
		power-off-delay-us = <5000000>;
		reset-gpios = <&gpio1 RK_PA6 GPIO_ACTIVE_LOW>;
	};

	vdd_0v9: regulator-0v9-vdd {
		compatible = "regulator-fixed";
		regulator-name = "vdd_0v9";
		regulator-min-microvolt = <900000>;
		regulator-max-microvolt = <900000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc_ddr: regulator-1v1-vcc-ddr {
		compatible = "regulator-fixed";
		regulator-name = "vcc_ddr";
		regulator-min-microvolt = <1100000>;
		regulator-max-microvolt = <1100000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc_1v8: regulator-1v8-vcc {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_3v3>;
	};

	/* S3 休眠域 1.8V —— 供 SARADC */
	vcc_1v8_s3: regulator-1v8-vcc-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8_s3";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_1v8>;
	};

	vcc_3v3: regulator-3v3-vcc {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc_3v3_lcd: regulator-3v3-lcd {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3_lcd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio0 RK_PA0 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		pinctrl-names = "default";
		pinctrl-0 = <&lcd_pwr_pin>;
		regulator-always-on;
		vin-supply = <&vcc5v0_sys>;
	};

	/* S3 休眠域 3.3V —— 供 USB2 PHY */
	vcc_3v3_s3: regulator-3v3-vcc-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3_s3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_3v3>;
	};

	vcc3v3_sd: regulator-3v3-vcc-sd {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_sd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio4 RK_PA1 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc_pwren_l>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_3v3>;
	};

	vcc5v0_sys: regulator-5v0-vcc-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-always-on;
		regulator-boot-on;
	};

	vcc5v0_usb: regulator-5v0-vcc-usb {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_usb";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc5v0_sys>;
	};

	vccio_sd: regulator-vccio-sd {
		compatible = "regulator-gpio";
		regulator-name = "vccio_sd";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <3300000>;
		gpios = <&gpio4 RK_PB6 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc_vol_ctrl_h>;
		startup-delay-us = <2000>;
		states = <1800000 0x0>, <3300000 0x1>;
		vin-supply = <&vcc5v0_sys>;
	};

	vdd_arm: regulator-vdd-arm {
		compatible = "pwm-regulator";
		regulator-name = "vdd_arm";
		regulator-min-microvolt = <746000>;
		regulator-max-microvolt = <1201000>;
		pwms = <&pwm1 0 5000 1>;
		pwm-supply = <&vcc5v0_sys>;
		regulator-always-on;
		regulator-boot-on;
		regulator-settling-time-up-us = <250>;
		regulator-pwm-continuous;
	};

	vdd_logic: regulator-vdd-logic {
		compatible = "pwm-regulator";
		regulator-name = "vdd_logic";
		regulator-min-microvolt = <705000>;
		regulator-max-microvolt = <1006000>;
		pwms = <&pwm2 0 5000 1>;
		pwm-supply = <&vcc5v0_sys>;
		regulator-always-on;
		regulator-boot-on;
		regulator-settling-time-up-us = <250>;
		regulator-pwm-continuous;
	};

	/* RNG - 严格对齐原厂 DTB 硬编码 */
	rng: rng@ffc50000 {
		compatible = "rockchip,rk3528-rng", "rockchip,rk3588-rng";
		reg = <0x0 0xffc50000 0x0 0x200>;
		interrupts = <GIC_SPI 23 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&scmi_clk 32>;
		clock-names = "hclk_trng";
		resets = <&cru 0xa3>;
		reset-names = "reset";
		status = "okay";
	};

	/* SFC SPI Flash Controller - 严格对齐原厂 DTB */
	sfc: spi@ffc00000 {
		compatible = "rockchip,sfc";
		reg = <0x0 0xffc00000 0x0 0x4000>;
		interrupts = <GIC_SPI 135 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&cru SCLK_SFC>, <&cru HCLK_SFC>;
		clock-names = "clk_sfc", "hclk_sfc";
		assigned-clocks = <&cru SCLK_SFC>;
		assigned-clock-rates = <100000000>;
		power-domains = <&power RK3528_PD_VPU>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";
	};
};

&combphy {
	status = "okay";
};

&cpu0 { cpu-supply = <&vdd_arm>; };
&cpu1 { cpu-supply = <&vdd_arm>; };
&cpu2 { cpu-supply = <&vdd_arm>; };
&cpu3 { cpu-supply = <&vdd_arm>; };

&gmac1 {
	clock_in_out = "output";
	phy-handle = <&rgmii_phy>;
	phy-mode = "rgmii-id";
	tx_delay = <0x3>;
	rx_delay = <0x6>;
	phy-supply = <&vcc_3v3>;
	pinctrl-names = "default";
	pinctrl-0 = <&rgmii_miim &rgmii_tx_bus2 &rgmii_rx_bus2 &rgmii_rgmii_clk &rgmii_rgmii_bus>;
	status = "okay";
};

&gpu {
	mali-supply = <&vdd_logic>;
	status = "okay";
};

/*
 * I2C1 + 触摸屏 (AXS5106)
 * 【关键】纯输入设备，不绑定任何 display 节点
 * 分辨率由芯片固件上报或用户空间 UI 框架映射，DTS 不硬编码
 */
&i2c1 {
	status = "okay";

	touchscreen@63 {
		compatible = "chipone,axs5106";
		reg = <0x63>;
		interrupt-parent = <&gpio1>;
		interrupts = <RK_PB0 IRQ_TYPE_LEVEL_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&tp_int_pin>, <&tp_reset_pin>;
		reset-gpios = <&gpio1 RK_PB1 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

&mdio1 {
	rgmii_phy: ethernet-phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x1>;
		reset-assert-us = <20000>;
		reset-deassert-us = <100000>;
		reset-gpios = <&gpio4 RK_PC2 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&gmac1_rstn_l>;
	};
};

&pinctrl {
	gmac {
		gmac1_rstn_l: gmac1-rstn-l {
			rockchip,pins = <4 RK_PC2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	ir {
		ir_int_pin: ir-int-pin {
			rockchip,pins = <4 RK_PC6 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	keys {
		key_reset_pin: key-reset-pin {
			rockchip,pins = <4 RK_PC1 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	lcd {
		lcd_pwr_pin: lcd-pwr-pin {
			rockchip,pins = <0 RK_PA0 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		lcd_bl_pin: lcd-bl-pin {
			rockchip,pins = <0 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	leds {
		led_4g_en: led-4g-en {
			rockchip,pins = <4 RK_PC0 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		led_5g_en: led-5g-en {
			rockchip,pins = <4 RK_PC3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		led_work_en: led-work-en {
			rockchip,pins = <4 RK_PB7 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	sdmmc {
		sdmmc_pwren_l: sdmmc-pwren-l {
			rockchip,pins = <4 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		sdmmc_vol_ctrl_h: sdmmc-vol-ctrl-h {
			rockchip,pins = <4 RK_PB6 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	spi1 {
		lcd_rs_pin: lcd-rs-pin {
			rockchip,pins = <1 RK_PB4 RK_FUNC_GPIO &pcfg_pull_up>;
		};
		lcd_rst_pin: lcd-rst-pin {
			rockchip,pins = <1 RK_PB5 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	/* 触摸屏 pinctrl —— 严格对齐原厂 DTB */
	touchscreen {
		tp_int_pin: tp-int-pin {
			rockchip,pins = <1 RK_PB0 RK_FUNC_GPIO &pcfg_pull_up>;
		};
		tp_reset_pin: tp-reset-pin {
			rockchip,pins = <1 RK_PB1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	wifi {
		wifi_reg_on: wifi-reg-on {
			rockchip,pins = <1 RK_PA6 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		wl_wake_host: wl-wake-host {
			rockchip,pins = <1 RK_PA7 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};
};

/* PWM1 → vdd_arm */
&pwm1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm1m0_pins>;
	status = "okay";
};

/* PWM2 → vdd_logic */
&pwm2 {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm2m0_pins>;
	status = "okay";
};

/* PWM6 → SPI 小屏背光 */
&pwm6 {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm6m0_pins>;
	status = "okay";
};

/* SARADC，vref 绑定 vcc_1v8_s3 */
&saradc {
	vref-supply = <&vcc_1v8_s3>;
	status = "okay";
};

&sdhci {
	bus-width = <8>;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
	non-removable;
	vmmc-supply = <&vcc_3v3>;
	vqmmc-supply = <&vcc_1v8>;
	pinctrl-names = "default";
	pinctrl-0 = <&emmc_bus8 &emmc_clk &emmc_cmd &emmc_strb>;
	status = "okay";
};

&sdmmc {
	bus-width = <4>;
	cap-sd-highspeed;
	disable-wp;
	max-frequency = <150000000>;
	rockchip,default-sample-phase = <90>;
	sd-uhs-sdr104;
	vmmc-supply = <&vcc3v3_sd>;
	vqmmc-supply = <&vccio_sd>;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_bus4 &sdmmc_clk &sdmmc_cmd &sdmmc_det>;
	status = "okay";
};

&sdio0 {
	#address-cells = <1>;
	#size-cells = <0>;
	bus-width = <4>;
	cap-sd-highspeed;
	cap-sdio-irq;
	supports-sdio;
	keep-power-in-suspend;
	no-sdio-pm;
	max-frequency = <200000000>;
	mmc-pwrseq = <&sdio_pwrseq>;
	non-removable;
	sd-uhs-sdr104;
	broken-cd;
	pinctrl-names = "default";
	pinctrl-0 = <&sdio0_bus4 &sdio0_cmd &sdio0_clk>;
	status = "okay";

	wifi@1 {
		compatible = "aic,aic8800";
		reg = <1>;
		interrupt-parent = <&gpio1>;
		interrupts = <RK_PA7 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "host-wake";
		pinctrl-names = "default";
		pinctrl-0 = <&wl_wake_host>;
	};
};

/* SFC SPI Flash 控制器 - pinctrl 和 flash 子节点 */
&sfc {
	pinctrl-names = "default";
	pinctrl-0 = <&fspi_pins>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <24000000>;
		spi-rx-bus-width = <4>;
		spi-tx-bus-width = <4>;
	};
};

/*
 * SPI1 多屏幕兼容配置
 * 【关键】仅保留原厂硬件控制属性，不写 width/height/rotate
 * 显示参数由 panel 驱动默认值或用户空间 UI 指定
 */
&spi1 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi1_pins>, <&lcd_rs_pin>, <&lcd_rst_pin>;
	spi-max-frequency = <15000000>;
	status = "okay";

	panel@0 {
		compatible = "sitronix,gc9307";
		reg = <0>;
		dc-gpios = <&gpio1 RK_PB4 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio1 RK_PB5 GPIO_ACTIVE_LOW>;
		power-supply = <&vcc_3v3_lcd>;
		backlight = <&backlight_lcd>;
		spi-max-frequency = <15000000>;
	};

	panel@2 {
		compatible = "sitronix,st7789v";
		reg = <2>;
		dc-gpios = <&gpio1 RK_PB4 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio1 RK_PB5 GPIO_ACTIVE_LOW>;
		power-supply = <&vcc_3v3_lcd>;
		backlight = <&backlight_lcd>;
		spi-max-frequency = <15000000>;
	};

	panel@3 {
		compatible = "sitronix,st7789v";
		reg = <3>;
		dc-gpios = <&gpio1 RK_PB4 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio1 RK_PB5 GPIO_ACTIVE_LOW>;
		power-supply = <&vcc_3v3_lcd>;
		backlight = <&backlight_lcd>;
		spi-max-frequency = <15000000>;
	};
};

&tsadc {
	status = "okay";
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0m0_xfer>;
	status = "okay";
};

&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart1m0_xfer>;
	status = "okay";
};

&uart2 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart2m1_ctsn &uart2m1_xfer>;
	status = "okay";
};

/* USB2 PHY 绑定 vcc_3v3_s3 (低功耗) */
&usb2phy {
	status = "okay";
};

&usb2phy_host {
	phy-supply = <&vcc_3v3_s3>;
	status = "okay";
};

&usb2phy_otg {
	phy-supply = <&vcc_3v3_s3>;
	status = "okay";
};

&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

&usb_host0_xhci {
	dr_mode = "otg";
	phys = <&usb2phy_otg>, <&combphy PHY_TYPE_USB3>;
	phy-names = "usb2-phy", "usb3-phy";
	phy_type = "utmi_wide";
	snps,dis_del_phy_power_chg_quirk;
	snps,dis_tx_ipgap_linecheck_quirk;
	snps,dis_u2_freeclk_exists_quirk;
	snps,dis_enblslpm_quirk;
	snps,dis_u2_susphy_quirk;
	status = "okay";
};
