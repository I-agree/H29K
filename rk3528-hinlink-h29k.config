CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y

# ==============================================================================
# 🌟 核心目标平台与专属设备激活 (完全对齐 Device/hinlink_h29k)
# ==============================================================================
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
# 👇 【核心纠错】必须是 TARGET_DEVICE_ 开头，且末尾严格对应你的 hinlink_h29k 宏名
CONFIG_TARGET_DEVICE_rockchip_armv8_DEVICE_hinlink_h29k=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_SQUASHFS_XZ=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="armv8"
# 👇 【注意】现代 OpenWrt 规范中，通过 Device 宏定义的设备，PROFILE 必须带 device_ 前缀
CONFIG_TARGET_PROFILE="device_hinlink_h29k"
CONFIG_TARGET_SQUASHFS_COMPRESSOR="xz"

# === Bootloader ===
CONFIG_PACKAGE_u-boot-hinlink-h29k-rk3528=y

# === 基础核心硬件支持 ===
CONFIG_PACKAGE_kernel=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-ledtrig-usbport=y
CONFIG_PACKAGE_kmod-usb-phy-rockchip=y
CONFIG_PACKAGE_kmod-scsi-core=y

CONFIG_PACKAGE_apk=y
CONFIG_PACKAGE_usbutils=y

# === IPv6 协议栈 ===
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# === 补齐 MBIM 协议栈接口（极其重要） ===
CONFIG_PACKAGE_umbim=y

# === 补齐 QMI 驱动栈（让 uqmi 真正生效） ===
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y

# === 界面美化与本地化组件 ===
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_ttf-dejavu=y

# 激活 SDIO 蓝牙支持选项
CONFIG_AIC8800_SDIO_BT_SUPPORT=y

# === 4G/5G 现代模块与网络核心 ===
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_qmi-utils=y
CONFIG_PACKAGE_mbimcli=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-rndis-host=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-aic8800-sdio=y
CONFIG_PACKAGE_aic8800-sdio-firmware=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-wdm=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_luci-i18n-qmodem-next-zh-cn=y
CONFIG_PACKAGE_comgt=y

# === 网页端挂载点管理（针对外接 U 盘/硬盘） ===
CONFIG_PACKAGE_luci-app-fstab=y
CONFIG_PACKAGE_luci-i18n-fstab-zh-cn=y

# 频率控制与监控 (温控必备)
CONFIG_PACKAGE_cpufrequtils=y

# 简单的网络测速 (排查 4G/5G 速度)
CONFIG_PACKAGE_speedtest-cli=y 

# === 生产力与跑分监控神器 ===
CONFIG_PACKAGE_htop=y

# === 编译构建、系统优化 ===
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-app-commands=y
CONFIG_PACKAGE_luci-i18n-commands-zh-cn=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-irqbalance=y
CONFIG_PACKAGE_luci-i18n-irqbalance-zh-cn=y

# === 隐私与安全 ===
CONFIG_PACKAGE_dnscrypt-proxy=y
CONFIG_PACKAGE_luci-app-dnscrypt-proxy=y
CONFIG_PACKAGE_luci-i18n-dnscrypt-proxy-zh-cn=y

# === 应用层工具组件与屏幕/按键核心补全 ===
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_graphicsmagick=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_fontconfig=y
CONFIG_PACKAGE_fontconfig-misc=y
CONFIG_PACKAGE_fbv=y
CONFIG_PACKAGE_input-event-daemon=y
CONFIG_PACKAGE_kmod-input-core=y
CONFIG_PACKAGE_kmod-input-evdev=y
CONFIG_PACKAGE_ca-bundle=y

# === 视频硬件核心 ===
CONFIG_PACKAGE_kmod-video-core=y
CONFIG_PACKAGE_kmod-video-uvc=y
CONFIG_PACKAGE_kmod-video-v4l2=y

# === 摄像头 V4L2 硬件参数深度调试工具 ===
CONFIG_PACKAGE_v4l2-utils=y

# === 音频硬件核心（支持麦克风与 HDMI 扬声器） ===
CONFIG_PACKAGE_kmod-sound-core=y
CONFIG_PACKAGE_kmod-usb-audio=y

# === 文件系统存储挂载与本地化编码 ===
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_exfatprogs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-nls-cp936=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_kmod-fs-cifs=y
CONFIG_PACKAGE_kmod-fs-netfs=y

# 高级硬盘/U盘全自动休眠插件
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y

# 网页端一键 Overlay 扩容神器（吃满闪存剩余空间）
CONFIG_PACKAGE_luci-app-partexp=y
CONFIG_PACKAGE_luci-i18n-partexp-zh-cn=y

# === 纯净主线 DRM/KMS 现代显示架构工具链 ===
CONFIG_PACKAGE_libdrm=y
CONFIG_PACKAGE_libdrm-tests=y

# === 用户态与内核态蓝牙全栈工具链 ===
CONFIG_PACKAGE_kmod-bluetooth=y
CONFIG_PACKAGE_bluez=y
CONFIG_PACKAGE_bluez-libs=y
CONFIG_PACKAGE_bluez-utils=y
CONFIG_PACKAGE_bluez-daemon=y

# PulseAudio主体+ A2DP 蓝牙音频
CONFIG_PACKAGE_pulseaudio-daemon-avahi=y

# LUCI蓝牙插件本体
CONFIG_PACKAGE_luci-app-bluetooth=y

# 音频基础依赖
CONFIG_PACKAGE_pulseaudio-daemon=y
CONFIG_PACKAGE_pulseaudio-bluez5=y
CONFIG_PACKAGE-pulseaudio-utils=y
CONFIG_PACKAGE_bluez-daemon=y 
CONFIG_PACKAGE_libsbc=y
CONFIG_PACKAGE_libfdk-aac=y
CONFIG_PACKAGE_alsa-lib=y
CONFIG_PACKAGE_alsa-utils=y
CONFIG_PACKAGE_libasound=y

#蓝牙配对必备
CONFIG_PACKAGE_socat=y

# === Ksmbd 轻量级网络共享 ===
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y
CONFIG_PACKAGE_ksmbd-server=y
CONFIG_PACKAGE_ksmbd-utils=y

# === 网络流量实时监控 ===
CONFIG_PACKAGE_bwm-ng=y

# === Docker 与 Firewall4 (Nftables) 完美共存兼容矩阵 ===
CONFIG_PACKAGE_firewall4=y
# CONFIG_PACKAGE_iptables-legacy is not set
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y

# === 生产力组件：完善 GraphicsMagick 的图片编解码管线 ===
CONFIG_PACKAGE_libjpeg=y
CONFIG_PACKAGE_libpng=y

# === Docker 核心组件与高并发网络依赖 ===
CONFIG_PACKAGE_kmod-bridge=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-fs-overlayfs=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-forward=y
CONFIG_PACKAGE_kmod-ikconfig=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker=y

# === LuCI Docker 图形化管理界面 ===
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y

# === 存储分区安全线全局深度扩容 ===
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# PHY 驱动与网卡必选
CONFIG_PACKAGE_kmod-phy-realtek=y
CONFIG_PACKAGE_kmod-phy-motorcomm=y
