# ==============================================================================
# 🌟 H29K OpenWrt 25.12 完整配置 (修订版 - 对齐内核 config-6.12)
# ==============================================================================

# === 核心目标平台与设备 ===
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_DEVICE_rockchip_armv8_DEVICE_hinlink_h29k=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="armv8"
CONFIG_TARGET_PROFILE="device_hinlink_h29k"

# === 根文件系统 ===
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=64
CONFIG_TARGET_SQUASHFS_ZSTD=y
CONFIG_TARGET_SQUASHFS_COMPRESSOR="zstd"
# CONFIG_TARGET_SQUASHFS_XZ is not set
CONFIG_TARGET_IMAGES_GZIP=y

# === 分区大小 ===
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# === Bootloader ===
CONFIG_PACKAGE_u-boot-hinlink-h29k-rk3528=y

# === 基础核心软件 ===
CONFIG_PACKAGE_apk=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipv6=y

# === WiFi 核心 (AIC8800 SDIO) ===
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-aic8800-sdio=y
CONFIG_PACKAGE_aic8800-sdio-firmware=y
CONFIG_PACKAGE_wpad-mbedtls=y
CONFIG_PACKAGE_wireless-tools=y

# === 4G/5G 模块完整 kmod 链 ===
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_pppoe-discovery=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_mbim-utils=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_luci-i18n-qmodem-next-zh-cn=y

# === 有线千兆 LAN 配套 ===
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_ethtool=y

# === 蓝牙完整协议栈 ===
CONFIG_PACKAGE_kmod-btsdio=y
CONFIG_PACKAGE_bluez-utils=y
CONFIG_PACKAGE_bluez-daemon=y
CONFIG_PACKAGE_bluez-firmware=y
CONFIG_PACKAGE_luci-app-bluetooth=y

# === 显示与多媒体 (ST7789V SPI屏 + UVC摄像头) ===
CONFIG_PACKAGE_fbv=y
CONFIG_PACKAGE_graphicsmagick=y
CONFIG_PACKAGE_libjpeg=y
CONFIG_PACKAGE_libpng=y
CONFIG_PACKAGE_fontconfig=y
CONFIG_PACKAGE_kmod-video-uvc=y
CONFIG_PACKAGE_v4l-utils=y
CONFIG_PACKAGE_alsa-utils=y
CONFIG_PACKAGE_kmod-sound-core=y

# === 红外遥控  ===
CONFIG_PACKAGE_ir-keytable=y
CONFIG_PACKAGE_input-event-daemon=y

# === 温控与频率管理  ===
CONFIG_PACKAGE_cpufrequtils=y
CONFIG_PACKAGE_kmod-hwmon-core=y

# === GPIO Keys  ===
CONFIG_PACKAGE_kmod-input-gpio-keys=y

# === SMB/CIFS 客户端  ===
CONFIG_PACKAGE_kmod-fs-cifs=y
CONFIG_PACKAGE_kmod-fs-netfs=y
CONFIG_PACKAGE_kmod-crypto-md5=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-hmac=y
CONFIG_PACKAGE_kmod-crypto-cmac=y

# === KSMBD 轻量级网络共享 ===
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y
CONFIG_PACKAGE_ksmbd-server=y
CONFIG_PACKAGE_ksmbd-utils=y

# === Docker 容器运行时 ===
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_containerd=y
CONFIG_PACKAGE_runc=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_kmod-docker-netfilter=y
CONFIG_PACKAGE_iptables-nft=y

# === 防火墙 ===
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# === LuCI 界面与中文化 ===
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-apk-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_uhttpd=y

# === 存储与挂载管理 ===
CONFIG_PACKAGE_luci-app-fstab=y
CONFIG_PACKAGE_luci-i18n-fstab-zh-cn=y
CONFIG_PACKAGE_luci-app-partexp=y
CONFIG_PACKAGE_luci-i18n-partexp-zh-cn=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_mountd=y

# === 系统监控与工具 ===
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_bwm-ng=y
CONFIG_PACKAGE_speedtest-cli=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-irqbalance=y
CONFIG_PACKAGE_luci-i18n-irqbalance-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-commands=y
CONFIG_PACKAGE_luci-i18n-commands-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

# === 隐私与安全 ===
CONFIG_PACKAGE_dnscrypt-proxy=y
CONFIG_PACKAGE_luci-app-dnscrypt-proxy=y
CONFIG_PACKAGE_luci-i18n-dnscrypt-proxy-zh-cn=y

# === 网络基础工具 ===
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_coreutils-timeout=y

# === 编译构建优化 ===
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y

# === 内核基础开关 ===
CONFIG_KERNEL_CRYPTO=y
CONFIG_PACKAGE_kmod-usb-core=y

# === 内核加密相关 ===
CONFIG_PACKAGE_kmod-crypto-lz4=y
CONFIG_PACKAGE_kmod-crypto-md5=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-hmac=y
CONFIG_PACKAGE_kmod-crypto-cmac=y

# === 屏幕与触摸驱动 ===
CONFIG_PACKAGE_kmod-axs5106=y
CONFIG_PACKAGE_kmod-drm-panel-sitronix-st7789v=y

# =================================================================
# 🌐 网络隧道与高级路由 (IPv4/IPv6)
# =================================================================
CONFIG_PACKAGE_kmod-ipip=y              # CONFIG_NET_IPIP
CONFIG_PACKAGE_kmod-ipgre=y             # CONFIG_NET_IPGRE + DEMUX
CONFIG_PACKAGE_kmod-gre=y               # 基础 GRE 依赖
CONFIG_PACKAGE_kmod-gre6=y              # CONFIG_IPV6_GRE
CONFIG_PACKAGE_kmod-ip6-tunnel=y        # CONFIG_IPV6_TUNNEL
CONFIG_PACKAGE_kmod-mip6=y              # CONFIG_IPV6_MIP6 (Mobile IPv6)

# =================================================================
# 🛡️ IPsec / XFRM 硬件卸载与加密
# =================================================================
# OpenWrt 将 AH/ESP/IPCOMP 等统一打包在 ipsec 相关模块中
CONFIG_PACKAGE_kmod-ipsec=y             # 基础 XFRM
CONFIG_PACKAGE_kmod-ipsec4=y            # IPv4 IPsec
CONFIG_PACKAGE_kmod-ipsec6=y            # CONFIG_IPV6_ESP / AH / COMP
# CONFIG_PACKAGE_kmod-ipsec-offload=y   # 如果有硬件卸载包 (XFRM_OFFLOAD)

# =================================================================
# 🔥 Netfilter 防火墙 / NAT / 桥接
# =================================================================
CONFIG_PACKAGE_kmod-ipt-nat=y           # CONFIG_IP_NF_NAT
CONFIG_PACKAGE_kmod-ipt-nat6=y          # CONFIG_NF_NAT64 / NAT66 (或 kmod-nf-nat6)
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-ebtables=y          # CONFIG_BRIDGE_NF_EBTABLES
CONFIG_PACKAGE_kmod-br-netfilter=y      # CONFIG_BRIDGE_NETFILTER
CONFIG_PACKAGE_kmod-nft-core=y          # CONFIG_NF_TABLES (通常默认已开)
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-nat6=y

# =================================================================
# 💾 文件系统 (FAT / EXFAT / NTFS / 固件打包)
# =================================================================
CONFIG_PACKAGE_kmod-fs-vfat=y           # CONFIG_VFAT_FS
CONFIG_PACKAGE_kmod-fs-exfat=y          # CONFIG_EXFAT_FS
CONFIG_PACKAGE_kmod-fs-ntfs3=y          # CONFIG_NTFS3_FS
CONFIG_PACKAGE_kmod-fs-squashfs=y       # CONFIG_SQUASHFS
CONFIG_PACKAGE_kmod-fs-ubifs=y          # CONFIG_UBIFS
CONFIG_PACKAGE_kmod-fs-jffs2=y          # CONFIG_JFFS2
CONFIG_PACKAGE_kmod-fs-autofs4=y        # CONFIG_AUTOFS4_FS
CONFIG_PACKAGE_kmod-fs-nfs=y            # CONFIG_NFS_FS
CONFIG_PACKAGE_kmod-fs-nfs-v4=y         # CONFIG_NFS_V4
CONFIG_PACKAGE_kmod-fuse=y              # CONFIG_FUSE

# =================================================================
# 🔗 容器与杂项
# =================================================================
CONFIG_PACKAGE_kmod-fs-overlayfs=y      # CONFIG_OVERLAY_FS (OpenWrt 核心，通常默认 y)
CONFIG_PACKAGE_kmod-binfmt-misc=y       # CONFIG_BINFMT_MISC

# =================================================================
# 🧮 加密库与数学运算 (Crypto/Math)
# =================================================================
# 对应 crypto/Kconfig 和 lib/Kconfig 中的 =m 项
CONFIG_PACKAGE_kmod-crypto-user=y       # CONFIG_CRYPTO_USER_API 系列
CONFIG_PACKAGE_kmod-lib-lz4hc=y         # CONFIG_LZ4HC_COMPRESS
CONFIG_PACKAGE_kmod-lib-842=y           # CONFIG_842_COMPRESS/DECOMPRESS
CONFIG_PACKAGE_kmod-lib-reed-solomon=y  # CONFIG_REED_SOLOMON
CONFIG_PACKAGE_kmod-lib-textsearch=y    # CONFIG_TEXTSEARCH_KMP/BM/FSM
CONFIG_PACKAGE_kmod-lib-crc-itu-t=y     # CONFIG_CRC_ITU_T
CONFIG_PACKAGE_kmod-lib-crc16=y         # CONFIG_CRC16
CONFIG_PACKAGE_kmod-lib-crc7=y          # CONFIG_CRC7
CONFIG_PACKAGE_kmod-lib-crc8=y          # CONFIG_CRC8
CONFIG_PACKAGE_kmod-lib-crc4=y          # CONFIG_CRC4
CONFIG_PACKAGE_kmod-lib-crc-t10dif=y    # CONFIG_CRC_T10DIF
CONFIG_PACKAGE_kmod-lib-crc-ccitt=y     # CONFIG_CRC_CCITT
CONFIG_PACKAGE_kmod-asn1-decoder=y      # CONFIG_ASN1_ENCODER (OpenWrt中通常叫 asn1-decoder)
CONFIG_PACKAGE_kmod-lib-polynomial=y    # CONFIG_POLYNOMIAL
