#
# rk3528-hinlink-h29k.config —— OpenWrt 25.12 + Linux 6.12.85 (VHE-Ready)
#

# === 基础构建开关 ===
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y

# === 目标平台与架构 ===
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=armv8
CONFIG_TARGET_ROCKCHIP_ARMV8_DEVICE_hinlink_h29k=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_ARCH_64BIT=y
CONFIG_ARCH_ARM64=y
CONFIG_ARCH_ROCKCHIP=y
CONFIG_SOC_RK3528=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="armv8"
CONFIG_TARGET_PROFILE="hinlink_h29k"
CONFIG_TARGET_KERNEL=6.12
CONFIG_KERNEL_PATCHVER=6.12.85

# === RK3528 Platform Mandatory Symbols (6.12.85) ===
CONFIG_ROCKCHIP_RK3528=y
CONFIG_ARM64_PA_BITS_40=y
CONFIG_SPARSEMEM_VMEMMAP=n
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_EPAN=y
CONFIG_ARM64_PAN=y
CONFIG_ARM64_UNMAP_KERNEL_AT_EL0=y
CONFIG_ARM64_VHE=y
CONFIG_ARM64_PA_BITS=40
CONFIG_ARM64_PA_BITS_40=y
CONFIG_ARM64_VA_BITS_48=y
# CONFIG_ARM64_VA_BITS_39 is not set
CONFIG_ARM64_ASIMD=y

# === IPv6 Protocol Stack ===
CONFIG_IPV6=y
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_ROUTE_INFO=y
CONFIG_IPV6_OPTIMISTIC_DAD=y
CONFIG_NETFILTER_FAMILY_IPV6=y
CONFIG_NF_CONNTRACK_IPV6=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_MANGLE=y
CONFIG_IP6_NF_RAW=y
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# === 显示子系统 —— ST7789V (6.12.85 V2 DRIVER) ===
# ⚠️ 6.12.85 废弃旧 st7789v.ko，必须用 v2 版本
CONFIG_DRM=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_DRM_ROCKCHIP_DW_MIPI_DSI=n
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_ST7789V_V2=y
CONFIG_DRM_ROCKCHIP_VOP2=y
CONFIG_FB=n
CONFIG_FB_CFB_FILLRECT=n
CONFIG_FB_CFB_COPYAREA=n
CONFIG_FB_CFB_IMAGEBLIT=n
CONFIG_FB_SYS_FILLRECT=n
CONFIG_FB_SYS_COPYAREA=n
CONFIG_FB_SYS_IMAGEBLIT=n
CONFIG_FB_FOREIGN_ENDIAN=n
CONFIG_FB_ROCKCHIP=n
CONFIG_FB_ROCKCHIP_LCDC=n
CONFIG_FB_TFT=n

# === 触控子系统 —— FT6236 ===
CONFIG_INPUT=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_POLLDEV=y
CONFIG_TOUCHSCREEN_FT6236=y

# === USB 子系统 —— DWC3 (6.12.85 PHY V2) ===
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_HOST=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_DWC3_DEBUG=y
CONFIG_USB_DWC3_ROCKCHIP=y
CONFIG_USB_DWC3_ROCKCHIP_PHY_V2=y

# === USB 网络驱动 ===
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_NET_RNDIS=y
CONFIG_USB_NET_RNDIS_HOST=y
CONFIG_USB_NET_CDC_MBIM=y
CONFIG_USB_NET_CDC_NCM=y
CONFIG_USB_NET_CDC_EEM=y
CONFIG_USB_NET_CDCETHER=n
CONFIG_USB_NET_CDC_SUBSET=n
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_OPTION=y
CONFIG_USB_SERIAL_QUALCOMM=y
CONFIG_USB_SERIAL_SIERRAWIRELESS=y
CONFIG_USB_SERIAL_WWAN=y
CONFIG_USB_WDM=y

# === WiFi 子系统 —— AIC8800 SDIO ===
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_ROCKCHIP=y
CONFIG_CFG80211=y
CONFIG_CFG80211_WEXT=y
CONFIG_MAC80211=y
CONFIG_MAC80211_RC_MINSTREL_HT=y
CONFIG_MAC80211_RC_DEFAULT_MINSTREL=y
CONFIG_MAC80211_RC_DEFAULT="minstrel_ht"
CONFIG_AIC8800_SDIO=y

# === SPI 子系统 —— ST7789V 通信总线 ===
CONFIG_SPI=y
CONFIG_SPI_MASTER=y
CONFIG_SPI_ROCKCHIP_SPI=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# === TCP & QoS ===
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_TCP_CONG="cubic"
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_QDISC="fq_codel"

# === 网络工具 ===
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_qmi-utils=y
CONFIG_PACKAGE_mbimcli=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-rndis-host=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-regulator-rk808=y
CONFIG_PACKAGE_kmod-fb-ST7789V=n
CONFIG_PACKAGE_kmod-aic8800-sdio=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_hostapd-utils=y
CONFIG_PACKAGE_wpad-openssl=y

# === 其他关键模块 ===
CONFIG_PACKAGE_kernel=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-ledtrig-usbport=y
CONFIG_PACKAGE_kmod-usb-phy-rockchip=y
CONFIG_PACKAGE_kmod-video-core=y
CONFIG_PACKAGE_kmod-video-uvc=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_luci-i18n-qmodem-next-zh-cn=y

# === 构建优化 ===
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y
CONFIG_COLLECT_KERNEL_DEBUG=y
CONFIG_DEBUG_FS=y
CONFIG_KALLSYMS=y
CONFIG_PRINTK_TIME=y
CONFIG_DEBUG_INFO=y
