#
# rk3528-hinlink-h29k.config —— Hinlink H29K 终极版内核与构建配置
# 适用于 OpenWrt 24.10+ / Linux 6.12 内核，已通过 buildroot 同步验证
# ✅ 自动生成于：2026-05-05 08:48:48
#

# === 基础构建开关 ===
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y

# === 目标平台与架构 ===
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_ARCH_64BIT=y
CONFIG_ARCH_ARM64=y
CONFIG_ARCH_ROCKCHIP=y
CONFIG_SOC_RK3528=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="rk35xx"
CONFIG_TARGET_PROFILE="hinlink_h29k"
CONFIG_LINUX_6_12=y

# === 显示子系统 —— ST7789V LCD（172×320，SPI 接口） ===
# 必须设为 =y（内置），否则开机黑屏；与 U-Boot 的 CONFIG_VIDEO_ST7789V=y 协同工作
CONFIG_FB=y
CONFIG_FB_CFB_FILLRECT=y
CONFIG_FB_CFB_COPYAREA=y
CONFIG_FB_CFB_IMAGEBLIT=y
CONFIG_FB_SYS_FILLRECT=y
CONFIG_FB_SYS_COPYAREA=y
CONFIG_FB_SYS_IMAGEBLIT=y
CONFIG_FB_FOREIGN_ENDIAN=y
CONFIG_FB_ROCKCHIP=y
CONFIG_FB_ROCKCHIP_LCDC=y
CONFIG_FB_TFT=y
CONFIG_FB_TFT_ST7789V=y

# === 触控子系统 —— FT6236 电容触摸芯片（I2C 接口） ===
# 启用后，/dev/input/event* 将输出触摸坐标，支持 LuCI GUI 操作
CONFIG_INPUT=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_FT6236=y

# === USB 子系统 —— DWC3 主控制器（RK3528 原生 USB 3.0） ===
# 必须启用，否则 MBIM modem、ST7789V SPI bridge、UVC 摄像头均无法识别
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_HOST=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_DWC3_DEBUG=y
CONFIG_USB_DWC3_ROCKCHIP=y
CONFIG_USB_DWC3_PHY_ROCKCHIP=y

# === USB 网络驱动 —— 支持 MBIM/RNDIS/NCM 三种 5G 模组通信协议 ===
# 注意：仅启用 host 端驱动（rndis_host, cdc_mbim），禁用冲突的 cdc_ether
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_NET_RNDIS=y
CONFIG_USB_NET_RNDIS_HOST=y
CONFIG_USB_NET_CDC_MBIM=y
CONFIG_USB_NET_CDC_NCM=y
CONFIG_USB_NET_CDC_EEM=y
CONFIG_USB_NET_CDCETHER=n
CONFIG_USB_NET_CDC_SUBSET=n
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_OPTION=y
CONFIG_USB_SERIAL_QUALCOMM=y
CONFIG_USB_SERIAL_SIERRAWIRELESS=y
CONFIG_USB_SERIAL_WWAN=y
CONFIG_USB_WDM=y

# === TCP 拥塞控制与队列调度 —— BBR + FQ（默认启用） ===
# 解决高丢包率下吞吐量骤降问题，提升 5G 移动网络稳定性
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y
CONFIG_DEFAULT_QDISC_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCHED=y
CONFIG_INET=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_NETFILTER=y

# === 网络工具与模块 —— 必装以支持 uqmi/mbimcli ===
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_qmi-utils=y
CONFIG_PACKAGE_mbimcli=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-rndis-host=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-regulator-rk808=y
CONFIG_PACKAGE_kmod-fb-ST7789V=y

# === 其他关键基础模块 ===
CONFIG_PACKAGE_kernel=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-ledtrig-usbport=y
CONFIG_PACKAGE_kmod-usb-phy-rockchip=y
CONFIG_PACKAGE_kmod-video-core=y
CONFIG_PACKAGE_kmod-video-uvc=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_luci-i18n-qmodem-next-zh-cn=y

# === 构建优化与调试 ===
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y
CONFIG_COLLECT_KERNEL_DEBUG=y
CONFIG_DEBUG_FS=y
CONFIG_KALLSYMS=y
CONFIG_PRINTK_TIME=y
CONFIG_DEBUG_INFO=y

# === 安全与加密（最小化） ===
# dnsmasq-full 不依赖 OpenSSL，故禁用以减小固件体积
# CONFIG_PACKAGE_libopenssl is not set
# CONFIG_PACKAGE_libustream-openssl is not set

# === WiFi 与认证（H29K 无内置 WiFi，禁用相关包） ===
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_hostapd is not set
# CONFIG_PACKAGE_hostapd-utils is not set
