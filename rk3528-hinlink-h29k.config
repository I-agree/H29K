CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# === 补齐 MBIM 协议栈接口（极其重要） ===
CONFIG_PACKAGE_umbim=y

# === 补齐 QMI 驱动栈（让 uqmi 真正生效） ===
