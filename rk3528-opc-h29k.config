# --- 核心 .config 注入 ---
# 2. 核心网络组合 (去弱留强)
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic is not set
# CONFIG_PACKAGE_wpad-mini is not set
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

# 3. FM350-GL USB/MBIM 模式支持
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-rndis-host=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_kmod-mtk_t7xx=y

# 4. Qmodem-Next 及其汉化
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_luci-i18n-qmodem-next-zh-cn=y
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-app-qmodem is not set

# 5. 屏幕驱动与内核组件
CONFIG_PACKAGE_kmod-h29k-fb-st7789v=y
CONFIG_PACKAGE_kmod-fb=y
CONFIG_PACKAGE_kmod-fb-cfb-fillrect=y
CONFIG_PACKAGE_kmod-fb-cfb-copyarea=y
CONFIG_PACKAGE_kmod-fb-cfb-imgblt=y

# 6. 系统工具与基础 UI
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-irqbalance=y
CONFIG_PACKAGE_luci-i18n-irqbalance-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_LUCI_LANG_zh_Hans=y

# 7. 固件全局定义
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
# CONFIG_TARGET_ROOTFS_JFFS2 is not set
