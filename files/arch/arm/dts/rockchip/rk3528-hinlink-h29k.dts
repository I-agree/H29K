/dts-v1/;
#include "rk3528.dtsi"
#include "rk3528-evb.dtsi"

/ {
    model = "HINLINK H29K";
    compatible = "hinlink,h29k", "rockchip,rk3528";

    chosen {
        stdout-path = "serial0:115200n8";
    };

    /* ====== MEMORY ====== */
    memory@80000000 {
        device_type = "memory";
        reg = <0x0 0x80000000 0x0 0x80000000>; /* 2GB */
    };

    /* ====== LEDS ====== */
    leds: leds {
        compatible = "gpio-leds";
        #address-cells = <1>;
        #size-cells = <0>;

        /* LED1: POWER (GPIO0_B0, active low) */
        power {
            label = "power";
            gpios = <&gpio0 8 GPIO_ACTIVE_LOW>; /* GPIO0_B0 → Pin#12 on 40pin header */
            linux,default-trigger = "default-on";
            default-state = "on";
        };

        /* LED2: WORK (GPIO0_B2, active high) */
        work {
            label = "work";
            gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>; /* GPIO0_B2 → Pin#14 */
            linux,default-trigger = "heartbeat";
        };

        /* LED3: STATUS (GPIO0_B3, active high) */
        status {
            label = "status";
            gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>; /* GPIO0_B3 → Pin#15 */
            linux,default-trigger = "cpu0";
        };
    };

    /* ====== KEYS ====== */
    keys: keys {
        compatible = "gpio-keys";
        #address-cells = <1>;
        #size-cells = <0>;
        autorepeat;

        /* KEY1: RESET (GPIO4_C3, active low) */
        reset {
            label = "reset";
            linux,code = <KEY_ESC>;
            gpios = <&gpio4 19 GPIO_ACTIVE_LOW>; /* GPIO4_C3 → Pin#36 */
            debounce-interval = <10>;
        };

        /* KEY2: USER (GPIO0_C0, active low) */
        user {
            label = "user";
            linux,code = <KEY_ENTER>;
            gpios = <&gpio0 16 GPIO_ACTIVE_LOW>; /* GPIO0_C0 → Pin#22 */
            debounce-interval = <10>;
        };
    };

    /* ====== REGULATORS ====== */
    pmu: power-management@ff600000 {
        compatible = "rockchip,rk3528-pmu";
        #address-cells = <2>;
        #size-cells = <2>;
        ranges;

        /* VCC_3V3: Power for LCD, Touch, SDIO, USB */
        vcc_3v3: vcc-3v3 {
            compatible = "regulator-fixed";
            regulator-name = "vcc_3v3";
            regulator-min-microvolt = <3300000>;
            regulator-max-microvolt = <3300000>;
            regulator-always-on;
            regulator-boot-on;
        };

        /* VCC_1V8: I/O voltage for LCD, Touch, UART */
        vcc_1v8: vcc-1v8 {
            compatible = "regulator-fixed";
            regulator-name = "vcc_1v8";
            regulator-min-microvolt = <1800000>;
            regulator-max-microvolt = <1800000>;
            regulator-always-on;
            regulator-boot-on;
        };

        /* VCC_5V: USB Host, GMAC PHY */
        vcc_5v: vcc-5v {
            compatible = "regulator-fixed";
            regulator-name = "vcc_5v";
            regulator-min-microvolt = <5000000>;
            regulator-max-microvolt = <5000000>;
            regulator-always-on;
            regulator-boot-on;
        };
    };

    /* ====== BACKLIGHT (PWM2) ====== */
    backlight: backlight {
        compatible = "pwm-backlight";
        pwms = <&pwm2 0 5000000 0>;
        brightness-levels = <
            0 16 32 48 64 80 96 112 128 144 160 176 192 208 224 240 255
        >;
        default-brightness-level = <16>;
        power-supply = <&vcc_3v3>;
    };

    /* ====== RTC (PCF8563 via I2C2) ====== */
    &i2c2 {
        status = "okay";
        clock-frequency = <100000>;

        rtc@51 {
            compatible = "nxp,pcf8563";
            reg = <0x51>;
            #clock-cells = <0>;
        };
    };

    /* ====== USB HOST (USB2.0) ====== */
    &usb_host0_ehci {
        status = "okay";
    };

    &usb_host0_ohci {
        status = "okay";
    };

    /* ====== USB OTG (USB2.0) ====== */
    &usb_otg0 {
        dr_mode = "otg";
        status = "okay";
    };

    /* ====== AUDIO (I2S0) ====== */
    &i2s0 {
        status = "disabled"; /* Optional: enable if using audio codec */
    };

    /* ====== UART0 (DEBUG) ====== */
    &uart0 {
        status = "okay";
        pinctrl-names = "default";
        pinctrl-0 = <&uart0m0_xfer>;
    };

    /* ====== UART2 (BLE/RS232) ====== */
    &uart2 {
        status = "okay";
        pinctrl-names = "default";
        pinctrl-0 = <&uart2m0_xfer>;
    };

    /* ====== ETHERNET (GMAC1) ====== */
    &gmac1 {
        phy-mode = "rgmii-id";
        phy-supply = <&vcc_3v3>;
        snps,reset-gpio = <&gpio4 18 GPIO_ACTIVE_LOW>; /* GPIO4_C2 */
        snps,reset-delays-us = <10000 20000 100000>;
        status = "okay";
    };

    /* ====== EMMC ====== */
    &emmc {
        status = "okay";
        mmc-hs200-1_8v;
        mmc-hs400-1_8v;
        no-sdio;
        no-sd;
        bus-width = <8>;
        cap-mmc-highspeed;
        cap-sd-highspeed;
        cap-power-off-card;
        disable-wp;
        broken-cd;
    };

    /* ====== SPI1 FOR GC9307 + XPT2046 ====== */
    &spi1 {
        status = "okay";
        /delete-node/ spidev@0;

        /* --- GC9307 LCD (HSX0147015001B-A0) --- */
        gc9307@0 {
            compatible = "rockchip,gc9307";
            reg = <0>;
            spi-max-frequency = <24000000>;
            #address-cells = <1>;
            #size-cells = <0>;

            vcc-supply = <&vcc_3v3>;
            vccio-supply = <&vcc_1v8>;

            reset-gpios = <&gpio0 12 GPIO_ACTIVE_LOW>; /* GPIO0_B4 */
            dc-gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;   /* GPIO0_B5 */
            backlight = <&backlight>;

            width = <172>;
            height = <320>;
            rotate = <0>;     /* 0° + swap-xy = landscape */
            fps = <60>;
            spi-cpol;        /* CPOL=1 required */
            spi-cpha;
            rockchip,spi-rx-bus-width = <0>;
            rockchip,spi-tx-bus-width = <1>;
            rgb;             /* GC9307 uses RGB565 */
            reset-duration-us = <15000>;
            vcom = <0x24>;
            gamma-curve = <0x04>;
            swap-xy;         /* Critical for horizontal display */
        };

        /* --- XPT2046 TOUCHSCREEN --- */
        xpt2046@1 {
            compatible = "ti,xpt2046";
            reg = <1>;
            spi-max-frequency = <2000000>;
            interrupt-parent = <&gpio0>;
            interrupts = <14 IRQ_TYPE_EDGE_FALLING>; /* GPIO0_B6 */
            ti,vref-delay-usecs = <100>;
            ti,keep-vref-on = <0>;
            ti,settle-delay-usecs = <150>;
            ti,pen-up-delay-usecs = <200>;
            ti,x-plate-ohms = <400>;
            ti,pressure-max = <255>;
            ti,x-min = <0>;
            ti,x-max = <171>;
            ti,y-min = <0>;
            ti,y-max = <319>;
            touchscreen-inverted-x;
            touchscreen-swapped-x-y;
            linux,swap-x-y;
            linux,ts-resistance-threshold = <200>;
        };
    };

    /* ====== PWM2 FOR BACKLIGHT ====== */
    &pwm2 {
        status = "okay";
    };

    /* ====== WATCHDOG ====== */
    &watchdog {
        status = "okay";
    };
};

/* ====== PINCTRL DEFINITIONS ====== */
&pinctrl {
    /* UART0: TX/RX */
    uart0m0_xfer: uart0m0-xfer {
        rockchip,pins = <
            RK_PA0 0x1001 /* uart0_tx */
            RK_PA1 0x1001 /* uart0_rx */
        >;
    };

    /* UART2: TX/RX */
    uart2m0_xfer: uart2m0-xfer {
        rockchip,pins = <
            RK_PC0 0x1001 /* uart2_tx */
            RK_PC1 0x1001 /* uart2_rx */
        >;
    };

    /* SPI1: CLK/MOSI/CS0/CS1 */
    spi1m0_pins: spi1m0-pins {
        rockchip,pins = <
            RK_PB0 0x1101 /* spi1_clk  → CPOL=1 needs pull-up */
            RK_PB1 0x1101 /* spi1_mosi */
        >;
    };

    spi1m0_cs0: spi1m0-cs0 {
        rockchip,pins = <
            RK_PB3 0x1101 /* spi1_cs0 */
        >;
    };

    spi1m0_cs1: spi1m0-cs1 {
        rockchip,pins = <
            RK_PB4 0x1101 /* spi1_cs1 → shared with LCD RESET */
        >;
    };

    /* LCD GPIOs: RESET & DC */
    lcd_gpio_pins: lcd-gpio-pins {
        rockchip,pins = <
            RK_PB4 0x1001 /* gpio0_b4 → RESET (and CS1!) */
            RK_PB5 0x1001 /* gpio0_b5 → DC */
        >;
    };

    /* TOUCH INTERRUPT */
    touch_int_pins: touch-int-pins {
        rockchip,pins = <
            RK_PB6 0x1001 /* gpio0_b6 → INT */
        >;
    };

    /* PWM2 */
    pwm2m0_pins: pwm2m0-pins {
        rockchip,pins = <
            RK_PG6 0x1001 /* pwm2_ch0 */
        >;
    };

    /* RESET BUTTON (GPIO4_C3) */
    key_reset_pins: key-reset-pins {
        rockchip,pins = <
            RK_PD3 0x1001 /* gpio4_c3 → RESET KEY */
        >;
    };

    /* USER BUTTON (GPIO0_C0) */
    key_user_pins: key-user-pins {
        rockchip,pins = <
            RK_PC0 0x1001 /* gpio0_c0 → USER KEY */
        >;
    };

    /* LED GPIOs */
    led_power_pins: led-power-pins {
        rockchip,pins = <
            RK_PB0 0x1001 /* gpio0_b0 → POWER LED */
        >;
    };

    led_work_pins: led-work-pins {
        rockchip,pins = <
            RK_PB2 0x1001 /* gpio0_b2 → WORK LED */
        >;
    };

    led_status_pins: led-status-pins {
        rockchip,pins = <
            RK_PB3 0x1001 /* gpio0_b3 → STATUS LED */
        >;
    };
};

/* ====== BIND PINCTRL TO NODES ====== */
&uart0 {
    pinctrl-names = "default";
    pinctrl-0 = <&uart0m0_xfer>;
};

&uart2 {
    pinctrl-names = "default";
    pinctrl-0 = <&uart2m0_xfer>;
};

&spi1 {
    pinctrl-names = "default";
    pinctrl-0 = <&spi1m0_pins &spi1m0_cs0 &spi1m0_cs1 &lcd_gpio_pins &touch_int_pins>;
};

&pwm2 {
    pinctrl-names = "default";
    pinctrl-0 = <&pwm2m0_pins>;
};

&gmac1 {
    pinctrl-names = "default";
    pinctrl-0 = <&gmac1m0_xfer>;
};

&keys {
    pinctrl-names = "default";
    pinctrl-0 = <&key_reset_pins &key_user_pins>;
};

&leds {
    pinctrl-names = "default";
    pinctrl-0 = <&led_power_pins &led_work_pins &led_status_pins>;
};
