/*
 * Device Tree Source for Hinlink H29K (RK3528)
 * - SoC: RK3528 (Cortex-A53 × 4)
 * - Display: ST7789V, 172×320, SPI, 3.3V
 * - Touch: FT6236, I²C, GPIO4_A0 (IRQ), GPIO4_B0 (RST)
 * - 5G: FM350-GL, connected via USB (not PCIe)
 * - PMIC: RK808 (I²C0)
 * - Boot: UART0 @ 115200n8
 */

#include "rk3528.dtsi"
#include "rk3528-opp.dtsi"

/ {
    model = "Hinlink H29K";
    compatible = "hinlink,h29k", "rockchip,rk3528";

    aliases {
        serial0 = &uart0;
        spi0 = &spi0;
        i2c1 = &i2c1;
        pwm2 = &pwm2;
        ethernet0 = &gmac;
        usb0 = &usb_host0_xhci;
        usb1 = &usb_otg0;
    };

    chosen {
        stdout-path = "serial0:115200n8";
        bootargs = "console=ttyS0,115200n8 earlycon=uart8250,mmio32,0xfeb50000 rootwait rw";
    };

    memory@10000000 {
        device_type = "memory";
        reg = <0x0 0x10000000 0x0 0x80000000>; /* 2GB */
    };

    leds {
        compatible = "gpio-leds";
        pinctrl-names = "default";
        pinctrl-0 = <&led_power>;

        power {
            label = "h29k:blue:power";
            gpios = <&gpio0 RK_PA0 GPIO_ACTIVE_HIGH>;
            default-state = "on";
        };
    };

    backlight: backlight {
        compatible = "pwm-backlight";
        pwms = <&pwm2 0 5000000 0>;
        brightness-levels = <0 4 8 16 32 64 128 255>;
        default-brightness-level = <255>;
        enable-gpios = <&gpio4 RK_PB0 GPIO_ACTIVE_HIGH>;
    };

    vcc3v3_lcd: vcc3v3-lcd-regulator {
        compatible = "regulator-fixed";
        regulator-name = "vcc3v3-lcd";
        regulator-min-microvolt = <3300000>;
        regulator-max-microvolt = <3300000>;
        regulator-always-on;
        regulator-boot-on;
    };

    vsp-supply = <&vcc3v3_lcd>;
    vsn-supply = <&vcc3v3_lcd>;

    panel@0 {
        compatible = "st,ST7789V", "simple-panel";
        reg = <0>;
        enable-gpios = <&gpio4 RK_PA7 GPIO_ACTIVE_HIGH>; /* LCD_EN */
        reset-gpios = <&gpio4 RK_PA6 GPIO_ACTIVE_LOW>;   /* LCD_RST */
        dc-gpios = <&gpio4 RK_PA5 GPIO_ACTIVE_HIGH>;     /* LCD_DC */
        backlight = <&backlight>;
        power-supply = <&vcc3v3_lcd>;
        rotation = <0>;
        video-mode = <0>; /* horizontal mode */

        port {
            panel_in: endpoint {
                remote-endpoint = <&spi0_out>;
            };
        };
    };

    touchscreen@38 {
        compatible = "focaltech,ft6236";
        reg = <0x38>;
        interrupt-parent = <&gpio4>;
        interrupts = <RK_PA0 IRQ_TYPE_EDGE_FALLING>;
        reset-gpios = <&gpio4 RK_PB0 GPIO_ACTIVE_LOW>;
        vcc-supply = <&vcc3v3_lcd>;
        vddio-supply = <&vcc3v3_lcd>;
        touchscreen-size-x = <320>;
        touchscreen-size-y = <172>;
        touchscreen-inverted-x;
        linux,code-base = <0x100>;
        status = "okay";
    };

    /* ST7789V on SPI0 */
    &spi0 {
        status = "okay";
        #address-cells = <1>;
        #size-cells = <0>;

        spi0_out: endpoint@0 {
            reg = <0>;
            remote-endpoint = <&panel_in>;
        };

        ST7789V@0 {
            compatible = "st,ST7789V";
            reg = <0>;
            spi-max-frequency = <20000000>;
            spi-cpol;
            spi-cpha;
            #address-cells = <1>;
            #size-cells = <0>;

            port {
                spi0_out: endpoint {
                    remote-endpoint = <&panel_in>;
                };
            };
        };
    };

    /* FT6236 on I2C1 */
    &i2c1 {
        status = "okay";
        #address-cells = <1>;
        #size-cells = <0>;

        ft6236@38 {
            compatible = "focaltech,ft6236";
            reg = <0x38>;
            interrupt-parent = <&gpio4>;
            interrupts = <RK_PA0 IRQ_TYPE_EDGE_FALLING>;
            reset-gpios = <&gpio4 RK_PB0 GPIO_ACTIVE_LOW>;
            vcc-supply = <&vcc3v3_lcd>;
            vddio-supply = <&vcc3v3_lcd>;
            touchscreen-size-x = <320>;
            touchscreen-size-y = <172>;
            touchscreen-inverted-x;
            linux,code-base = <0x100>;
            status = "okay";
        };
    };

    /* PWM2 for backlight */
    &pwm2 {
        status = "okay";
    };

    /* RK808 PMIC on I2C0 */
    &i2c0 {
        status = "okay";

        rk808: pmic@18 {
            compatible = "rockchip,rk808";
            reg = <0x18>;
            interrupt-parent = <&gpio0>;
            interrupts = <RK_PA2 IRQ_TYPE_LEVEL_LOW>;
            #clock-cells = <1>;
            clock-output-names = "xin32k", "rk808-clkout2";
            rockchip,system-power-controller;
            #address-cells = <1>;
            #size-cells = <0>;

            vcc1-supply = <&vcc3v3>;
            vcc2-supply = <&vcc3v3>;
            vcc3-supply = <&vcc3v3>;
            vcc4-supply = <&vcc3v3>;
            vcc5-supply = <&vcc3v3>;
            vcc6-supply = <&vcc3v3>;
            vcc7-supply = <&vcc3v3>;
            vcc8-supply = <&vcc3v3>;

            regulators {
                vdd_log: DCDC_REG1 {
                    regulator-name = "vdd_log";
                    regulator-min-microvolt = <712500>;
                    regulator-max-microvolt = <1450000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vdd_arm: DCDC_REG2 {
                    regulator-name = "vdd_arm";
                    regulator-min-microvolt = <712500>;
                    regulator-max-microvolt = <1450000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vdd_gpu: DCDC_REG3 {
                    regulator-name = "vdd_gpu";
                    regulator-min-microvolt = <712500>;
                    regulator-max-microvolt = <1450000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_ddr: DCDC_REG4 {
                    regulator-name = "vcc_ddr";
                    regulator-min-microvolt = <1000000>;
                    regulator-max-microvolt = <1200000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_io: LDO_REG1 {
                    regulator-name = "vcc_io";
                    regulator-min-microvolt = <3300000>;
                    regulator-max-microvolt = <3300000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc3v3: LDO_REG2 {
                    regulator-name = "vcc3v3";
                    regulator-min-microvolt = <3300000>;
                    regulator-max-microvolt = <3300000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc1v8: LDO_REG3 {
                    regulator-name = "vcc1v8";
                    regulator-min-microvolt = <1800000>;
                    regulator-max-microvolt = <1800000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_1v2: LDO_REG4 {
                    regulator-name = "vcc_1v2";
                    regulator-min-microvolt = <1200000>;
                    regulator-max-microvolt = <1200000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_1v1: LDO_REG5 {
                    regulator-name = "vcc_1v1";
                    regulator-min-microvolt = <1100000>;
                    regulator-max-microvolt = <1100000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_1v0: LDO_REG6 {
                    regulator-name = "vcc_1v0";
                    regulator-min-microvolt = <1000000>;
                    regulator-max-microvolt = <1000000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_0v9: LDO_REG7 {
                    regulator-name = "vcc_0v9";
                    regulator-min-microvolt = <900000>;
                    regulator-max-microvolt = <900000>;
                    regulator-always-on;
                    regulator-boot-on;
                };

                vcc_0v8: LDO_REG8 {
                    regulator-name = "vcc_0v8";
                    regulator-min-microvolt = <800000>;
                    regulator-max-microvolt = <800000>;
                    regulator-always-on;
                    regulator-boot-on;
                };
            };
        };
    };

    /* Thermal zones */
    thermal-zones {
        cpu_thermal: cpu-thermal {
            polling-delay-passive = <250>;
            polling-delay = <2000>;
            thermal-sensors = <&tsadc 0>;
            trips {
                cpu_alert0: trip-point@0 {
                    temperature = <85000>;
                    hysteresis = <2000>;
                    type = "passive";
                };
                cpu_crit: trip-point@1 {
                    temperature = <105000>;
                    hysteresis = <2000>;
                    type = "critical";
                };
            };
        };

        gpu_thermal: gpu-thermal {
            polling-delay-passive = <250>;
            polling-delay = <2000>;
            thermal-sensors = <&tsadc 1>;
            trips {
                gpu_alert0: trip-point@0 {
                    temperature = <85000>;
                    hysteresis = <2000>;
                    type = "passive";
                };
                gpu_crit: trip-point@1 {
                    temperature = <105000>;
                    hysteresis = <2000>;
                    type = "critical";
                };
            };
        };

        pmic_thermal: pmic-thermal {
            polling-delay-passive = <250>;
            polling-delay = <2000>;
            thermal-sensors = <&tsadc 2>;
            trips {
                pmic_alert0: trip-point@0 {
                    temperature = <100000>;
                    hysteresis = <2000>;
                    type = "passive";
                };
                pmic_crit: trip-point@1 {
                    temperature = <120000>;
                    hysteresis = <2000>;
                    type = "critical";
                };
            };
        };
    };

    /* GMAC Ethernet */
    &gmac {
        status = "okay";
        phy-mode = "rgmii";
        phy-handle = <&rgmii_phy>;
        rockchip,grf = <&grf>;
        #address-cells = <1>;
        #size-cells = <0>;

        mdio {
            #address-cells = <1>;
            #size-cells = <0>;

            rgmii_phy: ethernet-phy@0 {
                reg = <0>;
                phy-mode = "rgmii";
            };
        };
    };

    /* UART0 for console */
    &uart0 {
        status = "okay";
    };

    /* USB Host0 (USB3.0) — for FM350-GL */
    &usb_host0_xhci {
        status = "okay";
    };

    /* USB OTG0 (USB2.0) — for device mode / debug */
    &usb_otg0 {
        status = "okay";
        dr_mode = "otg";
    };

    /* GPIO pin control groups */
    &pmu_gpio0 {
        led_power: led-power {
            rockchip,pins = <0 RK_PA0 2 &pcfg_pull_none>;
        };
    };

    &gpio4 {
        lcd_pins: lcd-pins {
            rockchip,pins = <
                4 RK_PA5 2 &pcfg_pull_none	/* LCD_DC */
                4 RK_PA6 2 &pcfg_pull_none	/* LCD_RST */
                4 RK_PA7 2 &pcfg_pull_none	/* LCD_EN */
            >;
        };

        touch_irq_rst: touch-irq-rst {
            rockchip,pins = <
                4 RK_PA0 0 &pcfg_pull_none	/* IRQ */
                4 RK_PB0 2 &pcfg_pull_none	/* RST */
            >;
        };
    };

    /* EDID firmware loading hint (for DRM/KMS) */
    &edid {
        compatible = "rockchip,edid";
        status = "okay";
        edid-firmware = "edid/h29k.bin";
    };
};
