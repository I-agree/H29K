# RK3528-specific rockchip_defconfig for OpenWrt
# Path: target/linux/rockchip/files/arch/arm64/configs/rockchip_defconfig
# ✅ Loaded via 'CONFIG_EXTRA_KCONFIG_FILES' in target/linux/rockchip/Makefile
# ✅ Merged *after* generic/config-6.12 and rockchip/armv8/config-6.12
# ✅ Final symbol priority: files/ > armv8/ > generic/

#
# RK3528 SoC Core
#
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ARCH_MULTI_V8=y
CONFIG_ARM64_ERRATUM_2441130=y
CONFIG_ROCKCHIP_RK3528_PMU=y
CONFIG_ROCKCHIP_SARADC=y
CONFIG_ROCKCHIP_I2C=y
CONFIG_ROCKCHIP_DRM_VOP2=y
CONFIG_ROCKCHIP_VOP2_KMS=y
CONFIG_ROCKCHIP_RGA=y
CONFIG_ROCKCHIP_USBPHY=y
CONFIG_ROCKCHIP_USB3PHY=y
CONFIG_ROCKCHIP_EMMC=y
CONFIG_ROCKCHIP_SDIO=y
CONFIG_ROCKCHIP_SPI=y
CONFIG_ROCKCHIP_GPIO=y
CONFIG_ROCKCHIP_PINCTRL=y
CONFIG_ROCKCHIP_CLK_RK3528=y
CONFIG_ROCKCHIP_PM_DOMAINS=y
CONFIG_ROCKCHIP_PM=y
CONFIG_ROCKCHIP_CPUFREQ=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_ROCKCHIP_WATCHDOG=y
CONFIG_ROCKCHIP_WDT=y

#
# Storage & USB (H29K hardware)
#
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_ARMMMCI=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_ROCKCHIP=y
CONFIG_USB=y
CONFIG_USB_COMMON=y
CONFIG_USB_ARCH_HAS_HCD=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_ROCKCHIP=y
CONFIG_USB_DWC3_GADGET=y

#
# Minimal required subsystems
#
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_EXT4_FS=y
CONFIG_PRINTK=y
CONFIG_DEBUG_FS=y
CONFIG_MAGIC_SYSRQ=y

#
# Explicitly disable unsupported features (prevents auto-enable via generic config)
#
# Audio — H29K has no codec or I2S routing
CONFIG_SND_SOC_ROCKCHIP=n
CONFIG_SND_SOC_ROCKCHIP_I2S=n
CONFIG_SND_SOC_ROCKCHIP_SPDIF=n
CONFIG_SND_SOC_ROCKCHIP_HDMI=n

# PCIe — H29K has no PCIe slot or controller
CONFIG_PCIE_ROCKCHIP_HOST=n
CONFIG_PCIE_ROCKCHIP_EP=n

# HDMI CEC / IR — no hardware
CONFIG_RC_CORE=n
CONFIG_RC_DEVICES=n

# Bluetooth / WiFi modules — not on-board (USB-only)
CONFIG_BT=n
CONFIG_CFG80211=n
CONFIG_MAC80211=n

# GPU acceleration (Mali) — not used in OpenWrt headless context
CONFIG_DRM_ARMADA=n
CONFIG_DRM_ETNAVIV=n
CONFIG_DRM_PANFROST=n

# Legacy Rockchip drivers (RK3288/RK3399 only)
CONFIG_ROCKCHIP_IOMMU=n
CONFIG_ROCKCHIP_RK3399_DMC=n
CONFIG_ROCKCHIP_RK3328_DMC=n
