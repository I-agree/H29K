#
# Hinlink H29K (RK3528) - OpenWrt 25.12 + linux-6.12.85 compliant defconfig
# Generated for: USB 5G (FM350-GL), ST7789V 172×320 LCD, RK808 PMIC, eMMC boot
#

CONFIG_TARGET_PROFILE_HINLINK_H29K=y

# === Partitioning & Image Layout (used by image/Makefile) ===
CONFIG_TARGET_KERNEL_PARTSIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=2048
CONFIG_TARGET_IMAGES_PAD=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PACKAGE=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y

# === Rockchip-specific target options ===
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_rk3528=y

# === RK3528 SoC Core Support (MANDATORY - DO NOT REMOVE) ===
# These enable the hardware blocks and satisfy Kconfig dependencies
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ARCH_MULTI_V8=y
CONFIG_ARM64_ERRATUM_2441130=y
CONFIG_ROCKCHIP_RK3528_PMU=y
CONFIG_ROCKCHIP_SARADC=y
CONFIG_ROCKCHIP_I2C=y
CONFIG_ROCKCHIP_DRM_VOP2=y
CONFIG_ROCKCHIP_VOP2_KMS=y
CONFIG_ROCKCHIP_RGA=y
CONFIG_ROCKCHIP_USBPHY=y
CONFIG_ROCKCHIP_USB3PHY=y
CONFIG_ROCKCHIP_EMMC=y
CONFIG_ROCKCHIP_SDIO=y
CONFIG_ROCKCHIP_SPI=y
CONFIG_ROCKCHIP_GPIO=y
CONFIG_ROCKCHIP_PINCTRL=y
CONFIG_ROCKCHIP_CLK_RK3528=y
CONFIG_ROCKCHIP_PM_DOMAINS=y
CONFIG_ROCKCHIP_PM=y
CONFIG_ROCKCHIP_CPUFREQ=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_ROCKCHIP_WATCHDOG=y
CONFIG_ROCKCHIP_WDT=y

# === Display: ST7789V via DRM VOP2 (NOT framebuffer) ===
# ST7789V is driven by DRM panel driver (builtin), not fbdev
CONFIG_DRM_ROCKCHIP=y
CONFIG_DRM_ROCKCHIP_VOP2=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_ST7789V=y
CONFIG_DRM_BRIDGE_ANALOGIX_ANX6345=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_PWM_ROCKCHIP=y

# === Touch & Input ===
CONFIG_INPUT_FT6236=y

# === Power & PMIC ===
CONFIG_REGULATOR_RK808=y

# === Storage & USB ===
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_ROCKCHIP=y
CONFIG_MMC_SDHCI_ROCKCHIP=y
CONFIG_USB=y
CONFIG_USB_COMMON=y
CONFIG_USB_ARCH_HAS_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_STORAGE_UAS=y
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_OPTION=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y

# === USB 5G essential support (qmi_wwan + mbim + firmware loading) ===
CONFIG_USB_NET_QMI_WWAN=y
CONFIG_USB_NET_CDC_MBIM=y
CONFIG_USB_SERIAL_OPTION=y
CONFIG_COMGT=y
CONFIG_UQMI=y
CONFIG_USBMODE=y
CONFIG_LUCI_PROTO_QMI=y
CONFIG_LUCI_PROTO_MBIM=y

# === Debug & Diagnostics ===
CONFIG_PRINTK=y
CONFIG_DEBUG_FS=y
CONFIG_DMESG=y
CONFIG_LOGREAD=y
CONFIG_ETHTOOL=y
CONFIG_USBUTILS=y
CONFIG_LSUSB=y

# === Minimal UI ===
CONFIG_LUCI_APP_UHTTPD=y
CONFIG_LUCI_APP_FIREWALL=y
CONFIG_LUCI_THEME_BOOTSTRAP=y
CONFIG_LUCI_I18N_BASE_ZH_CN=y
