DEVICE_VENDOR:=Hinlink
DEVICE_MODEL:=H29K
DEVICE_VARIANT:=RK3528
DEVICE_PACKAGES:=kmod-usb-net-rndis-host kmod-usb-net-cdc-mbim kmod-usb-serial-option uqmi qmi-utils mbimcli luci-proto-qmi luci-proto-mbim luci-app-ttyd luci-i18n-base-zh-cn luci-i18n-firewall-zh-cn luci-i18n-uhttpd-zh-cn kmod-regulator-rk808 kmod-fb-st7789v-v2 kmod-video-uvc
DEVICE_DTS:=rockchip/rk3528-hinlink-h29k
IMAGE_SIZE:=32m
KERNEL_SIZE:=256k
ROOTFS_SIZE:=2048k
IMAGE/sysupgrade.bin := sysupgrade-tar | append-metadata | check-size $$$$(IMAGE_SIZE)
IMAGE/factory.img := boot-img | pad-rootfs | check-size $$$$(IMAGE_SIZE)
BOOT_IMG_NAME:=boot.img
BOOT_IMG_KERNEL:=arch/arm64/boot/Image
BOOT_IMG_INITRAMFS:=
BOOT_IMG_DTB:=arch/arm64/boot/dts/rockchip/rk3528-hinlink-h29k.dtb
BOOT_IMG_CMDLINE:=console=ttys0,115200n8 rw root=/dev/mmcblk0p2 rootwait earlycon=uart8250,mmio32,0xff1a0000
DEVICE_PROFILE:=hinlink_h29k
LUCI_DEFAULT_THEME:=bootstrap
LUCI_DEFAULT_LANG:=zh_cn
LUCI_DEFAULT_PACKAGES:=luci-app-firewall luci-app-uhttpd luci-app-ttyd
IMAGEOPT:=--no-strip --no-debug-info --compress gzip --pad-rootfs
DEVICE_COMPAT_VERSION:=25.12.85
DEVICE_COMPAT_MESSAGE:=Hinlink H29K (RK3528) running OpenWrt 25.12.85
CONFIG_TARGET_rockchip_rk3528=y
CONFIG_TARGET_rockchip_rk3528_DEVICE_hinlink_h29k=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
