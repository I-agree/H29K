# Hinlink H29K (RK3528) U-Boot defconfig
# OpenWrt 25.12+ Linux6.12

CONFIG_ARM=y
CONFIG_ARM64=y
CONFIG_SKIP_LOWLEVEL_INIT=y
CONFIG_COUNTER_FREQUENCY=24000000
CONFIG_ARCH_ROCKCHIP=y
CONFIG_SYS_SOC="rockchip"
CONFIG_ROCKCHIP_RK3528=y
# CONFIG_OF_UPSTREAM is not set
CONFIG_DEFAULT_DEVICE_TREE="rockchip/rk3528-hinlink-h29k"
CONFIG_DEFAULT_FDT_FILE="rockchip/rk3528-hinlink-h29k.dtb"

CONFIG_SYS_LOAD_ADDR=0x08080000
CONFIG_TEXT_BASE=0x00040000

# Serial (Rockchip UART, NO NS16550)
CONFIG_DEBUG_UART=y
CONFIG_DEBUG_UART_BASE=0xFF9F0000
CONFIG_DEBUG_UART_CLOCK=24000000
CONFIG_DEBUG_UART_ANNOUNCE=y
CONFIG_DEBUG_UART_SKIP_INIT=y
CONFIG_DEBUG_UART_SHIFT=2
CONFIG_ROCKCHIP_SERIAL=y
CONFIG_DEBUG_UART_ROCKCHIP=y
CONFIG_BAUDRATE=1500000

# SPL / FIT / ATF
CONFIG_FIT=y
CONFIG_SPL=y
CONFIG_SPL_FRAMEWORK=y
CONFIG_SPL_LIBCOMMON_SUPPORT=y
CONFIG_SPL_LIBGENERIC_SUPPORT=y
CONFIG_SPL_SERIAL_SUPPORT=y
CONFIG_SPL_GPIO_SUPPORT=y
CONFIG_SPL_MMC_SUPPORT=y
CONFIG_SPL_SEPARATE_BSS=y
CONFIG_SPL_LOAD_FIT=y
CONFIG_SPL_ATF=y
CONFIG_BINMAN=y
CONFIG_SPL_STACK_R=y
CONFIG_SPL_STACK_R_ADDR=0x00400000

# Device tree
CONFIG_OF_CONTROL=y
CONFIG_SPL_OF_CONTROL=y
CONFIG_OF_SPL_REMOVE_PROPS="clock-names interrupt-parent assigned-clocks assigned-clock-rates assigned-clock-parents"

# Driver model
CONFIG_DM=y
CONFIG_SPL_DM=y
CONFIG_DM_GPIO=y
CONFIG_DM_MMC=y
CONFIG_DM_ETH=y
CONFIG_DM_MDIO=y

# Memory
CONFIG_SYS_MALLOC_LEN=0x1000000
CONFIG_SYS_MALLOC_F_LEN=0x4000
CONFIG_NR_DRAM_BANKS=2
CONFIG_HAS_CUSTOM_SYS_INIT_SP_ADDR=y
CONFIG_CUSTOM_SYS_INIT_SP_ADDR=0x00c00000
CONFIG_SPL_STACK=0x00400000
CONFIG_SPL_BSS_START_ADDR=0x00408000
CONFIG_SPL_BSS_MAX_SIZE=0x4000
CONFIG_SPL_MAX_SIZE=0x40000

# MMC / eMMC
CONFIG_MMC=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_SDMA=y
CONFIG_MMC_SDHCI_ROCKCHIP=y
CONFIG_SUPPORT_EMMC_RPMB=y

# Ethernet
CONFIG_PHY_REALTEK=y
CONFIG_DWC_ETH_QOS=y
CONFIG_DWC_ETH_QOS_ROCKCHIP=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_GENERIC=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GENERIC=y
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_DOWNLOAD=y
# CONFIG_USB_FUNCTION_FASTBOOT is not set
# CONFIG_UDP_FUNCTION_FASTBOOT is not set
# CONFIG_TCP_FUNCTION_FASTBOOT is not set
CONFIG_USB_FUNCTION_ROCKUSB=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PHY_ROCKCHIP_NANENG_COMBOPHY=y
CONFIG_FASTBOOT_BUF_ADDR=0x08080000

# PWM / Regulator / LED / Button
CONFIG_PWM_ROCKCHIP=y
CONFIG_REGULATOR_PWM=y
CONFIG_DM_REGULATOR_GPIO=y
CONFIG_LED=y
CONFIG_LED_GPIO=y
CONFIG_BUTTON=y
CONFIG_BUTTON_ADC=y
CONFIG_ROCKCHIP_GPIO=y

# Commands
CONFIG_CMD_MEMINFO=y
CONFIG_CMD_MEMINFO_MAP=y
CONFIG_CMD_ADC=y
CONFIG_CMD_GPIO=y
CONFIG_CMD_GPT=y
CONFIG_CMD_MISC=y
CONFIG_CMD_MMC=y
CONFIG_CMD_USB=y
CONFIG_CMD_ROCKUSB=y
CONFIG_CMD_USB_MASS_STORAGE=y
CONFIG_CMD_RNG=y
CONFIG_CMD_REGULATOR=y
CONFIG_CMD_BOOTI=y
CONFIG_CMD_PART=y
CONFIG_CMD_FS_GENERIC=y
CONFIG_CMD_FAT=y
CONFIG_CMD_EXT4=y

# Environment (MMC + redundant)
CONFIG_ENV_IS_IN_MMC=y
CONFIG_SYS_MMC_ENV_DEV=0
CONFIG_ENV_OFFSET=0x3f8000
CONFIG_ENV_SIZE=0x8000
CONFIG_SYS_REDUNDANT_ENVIRONMENT=y
CONFIG_ENV_OFFSET_REDUND=0x3f0000
CONFIG_BOOTSTD=y
CONFIG_BOOTSTD_FULL=y
CONFIG_BOOTSTD_BOOTCOMMAND=y

# Boot args / console
CONFIG_EXTRA_ENV_SETTINGS="soc=rk3528\0kernel_addr_r=0x03000000\0fdt_addr_r=0x07f00000\0ramdisk_addr_r=0x0a200000\0"
CONFIG_REQUIRE_SERIAL_CONSOLE=y
CONFIG_BOOTDELAY=0
CONFIG_AUTOBOOT_KEYED=y
CONFIG_AUTOBOOT_STOP_STR="stop"
CONFIG_SYS_CONSOLE_INFO_QUIET=y

# Misc
CONFIG_BOARD_RNG_SEED=y
CONFIG_ERRNO_STR=y
# CONFIG_DISPLAY_CPUINFO is not set