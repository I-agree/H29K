CONFIG_ENV_OFFSET=0x00002000
CONFIG_ENV_SIZE=0x2000
CONFIG_ENV_OFFSET_REDUND=0x00004000
CONFIG_ENV_SIZE_REDUND=0x2000

# Boot commands (critical for your sysupgrade workflow)
CONFIG_EXTRA_ENV_SETTINGS="\
bootdelay=1\0\
baudrate=115200\0\
console=ttyS2,115200\0\
kernel_addr_r=0x02000000\0\
fdt_addr_r=0x01f00000\0\
ramdisk_addr_r=0x02100000\0\
scriptaddr=0x00010000\0\
pxefile_addr_r=0x00100000\0\
fit_addr_r=0x01e00000\0\
boot_fit=bootm ${fit_addr_r}#config-1\0\
bootcmd=run boot_fit\0\
bootargs=console=${console} earlycon=rockchip,0xfe310000 root=PARTUUID=${uuid} rw rootwait init=/sbin/init\0\
kernel_partsize=256\0\
rootfs_partsize=2048\0"

# Command line editing & networking
CONFIG_CMDLINE_EDITING=y
CONFIG_AUTO_COMPLETE=y
